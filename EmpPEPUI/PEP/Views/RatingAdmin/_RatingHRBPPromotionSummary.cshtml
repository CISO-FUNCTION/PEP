
<link href="~/Content/themes/base/jquery-ui.css" rel="stylesheet" />
<style>
    .norm-doc-download {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .norm-doc-download button {
            margin-bottom: 10px;
        }

    #hrbpAdmin_prom_chart {
        height: 400px;
    }

        #hrbpAdmin_prom_chart svg.highcharts-root {
            font-size: 16px !important;
        }


    .highcharts-figure,
    .highcharts-data-table table {
        min-width: 310px;
        max-width: 800px;
        margin: 1em auto;
    }

    .highcharts-data-table table {
        font-family: Verdana, sans-serif;
        border-collapse: collapse;
        border: 1px solid #ebebeb;
        margin: 10px auto;
        text-align: center;
        width: 100%;
        max-width: 500px;
    }

    .highcharts-data-table caption {
        padding: 1em 0;
        font-size: 1.2em;
        color: #555;
    }

    .highcharts-data-table th {
        font-weight: 600;
        padding: 0.5em;
    }

    .highcharts-data-table td,
    .highcharts-data-table th,
    .highcharts-data-table caption {
        padding: 0.5em;
    }

    .highcharts-data-table thead tr,
    .highcharts-data-table tr:nth-child(even) {
        background: #f8f8f8;
    }

    .highcharts-data-table tr:hover {
        background: #f1f7ff;
    }

    label.filterAttr {
        width: 100%;
        /*display: flex;
        align-items: center;
        justify-content: space-between;*/
    }


        label.filterAttr .form-control {
            font-size: 11.5px;
        }

        /*label.filterAttr button.multiselect.dropdown-toggle.btn.btn-default:hover {
            transform: scale(1);
        }*/

        label.filterAttr ul.multiselect-container.dropdown-menu {
            max-width: 100% !important;
            width: 100% !important;
            top: 35px !important;
        }


    .col-md-12.filter-top-sec-item2:after {
        content: "";
        position: absolute;
        top: -16px;
        right: 18px;
        margin-left: -6px;
        border-width: 8px;
        border-style: solid;
        border-color: transparent transparent #ddd transparent;
    }

    .col-md-12.filter-top-sec-item2 {
        position: relative;
        margin-top: 10px;
        background: #fff;
        padding: 0px 16px 16px;
        display: block;
        width: 100%;
        left: 0;
        top: 0px;
        z-index: 9;
        box-shadow: 0 15px 18px -14px #00000091;
        border-radius: 4px;
        margin-bottom: 10px;
    }

    /*.col-md-12.filter-top-sec-item2 span#close-filter2 {
            position: absolute;
            right: 17px;
            font-size: 20px;
            background: #5650c6;
            color: #fff;
            padding: 5px;
            border-radius: 100%;
            z-index: 9;
        }*/

    .filter-img-sec {
        text-align: right;
    }

        .filter-img-sec #open-filter2 {
            background: #2e84e7;
            color: #fff;
            font-size: 16px;
            border-radius: 4px;
            padding: 4px 4px 0px;
            cursor: pointer;
            height: auto !important;
            border: none;
            outline: none;
            display: none;
        }

        .filter-img-sec #close-filter2 {
            background: #000;
            color: #fff;
            font-size: 16px;
            border-radius: 4px;
            padding: 4px 4px 0px;
            cursor: pointer;
            height: auto !important;
            border: none;
            outline: none;
        }

    /*.multiselect-container.dropdown-menu input[type='radio'] {
        display: none;
    }*/
</style>
<div id="main-wrapper01">
    @*<div id="loading-overlay">
            <img src="~/images/loading.gif" alt="Loading..." id="loading-image" />
        </div>*@

    <div class="container-fluid">
        @*<div class="row" id="RatingAppcycleDiv">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="col-md-3 control-label">Appraisal Cycle :</label>
                        <div class="col-md-3">
                            <select id="ddlRating" class="form-control"></select>
                        </div>
                    </div>
                </div>
            </div>*@
        <div class="row" style="position: relative;">
            <div class="col-md-12">
                <div class="filter-img-sec">
                    <button title="Filter" id="open-filter2"><span class="glyphicon glyphicon-filter"></span></button>
                    <button id="close-filter2"><span class="glyphicon glyphicon-remove"></span></button>
                </div>
            </div>
            <div class="col-md-12 filter-top-sec-item2">
                <h5 class="reprt-heading-title"><b>Filters</b></h5>
                <div class="filter-top-item">
                    <div class="row">
                        <div class="col-md-2">
                            <label class="GDLDeptHead filterAttr" style="font-size:11px">
                                <span class="text-label">Approver Span</span>
                                <span><select class="form-control" id="ddlGDLDept_headPromo" multiple="multiple" onchange="Promofilterschange('GDL');"></select></span>
                            </label>
                        </div>
                        <div class="col-md-2">
                            <label class="RMSpan filterAttr" style="font-size:11px">
                                <span class="text-label">Reviewer  Span</span>
                                <span><select class="form-control" id="ddlDPSpan_headPromo" multiple="multiple" onchange="Promofilterschange('DP');"></select></span>
                            </label>
                        </div>
                        <div class="col-md-2">
                            <label class="RMSpan filterAttr" style="font-size:11px">
                                <span class="text-label">Inputter Span</span>
                                <span><select class="form-control" id="ddlRMSpan_headPromo" multiple="multiple" onchange="Promofilterschange('RM');"></select></span>
                            </label>
                        </div>

                        <div class="col-md-2">
                            <label class="Grade filterAttr" style="font-size:11px">
                                <span class="text-label"> Grade</span>
                                <span><select class="form-control" multiple="multiple" id="ddlgrade_HRBPAdminPromo" onchange="Promofilterschange('--');"><option value="0">--select--</option></select></span>
                            </label>
                        </div>
                        <div class="col-md-2">
                            <label class="Location filterAttr" style="font-size:11px">
                                <span class="text-label"> Location</span>
                                <span><select class="form-control" multiple="multiple" id="ddllocation_HRBPAdminPromo" onchange="Promofilterschange('--');"><option value="1">India</option><option value="3">US</option><option value="2">Rest Of World</option></select></span>
                            </label>
                        </div>
                        <div class="col-md-2">
                            <label class="GroupAccount filterAttr" style="font-size:11px;">
                                <span class="text-label"> Group Account</span>
                                <span><select class="form-control" multiple="multiple" id="ddlgroupaccount_HRBPAdminPromo" onchange="Promofilterschange('--');"><option value="0">--select--</option></select></span>
                            </label>
                        </div>
                        <div class="col-md-2">
                            <label class="Gender filterAttr" style="font-size:11px;">
                                <span class="text-label">Gender</span>
                                <span><select class="form-control" multiple="multiple" id="ddlgender_HRBPAdminPromo" onchange="Promofilterschange('--');"><option value="0">--select--</option></select></span>
                            </label>
                        </div>
                        <div class="col-md-2">
                            <label class="EmployeeStatus filterAttr" style="font-size:11px;">
                                <span class="text-label">Employee Status</span>
                                <span><select class="form-control" multiple="multiple" id="ddlEmployeeStatus_HRBPAdminPromo" onchange="Promofilterschange('--');"><option value="0">--select--</option></select></span>
                            </label>
                        </div>
                        <div class="col-md-2">
                            <label class="DeliveryNorm filterAttr" style="font-size:11px;">
                                <span class="text-label">Delivery/ Non-delivery</span>
                                <span><select class="form-control" multiple="multiple" id="ddlDeliveryStatus_Prom" onchange="Promofilterschange('--')"><option value="0">--select--</option></select></span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="norm-doc-download-top" style="margin-bottom:10px;">
            <div class="norm-doc-download">
                <div style="text-align: left;">
                    <h5 class="reprt-heading-title"><b>Promotion Summary Details</b></h5>
                </div>

                <a class="form-control" style="width:122px;" onclick="return tableToExcel('tblHRBPAdminPromotionSummary', 'Promotion Summary Details', 'BtnAdminPromotionSummary')" id="BtnAdminPromotionSummary">
                    <i class="fa fa-file-excel-o"></i>
                </a>

            </div>
        </div>
        <table id="tblHRBPAdminPromotionSummary" class="table table-striped table-bordered nowrap data-table-main" style="width:100%">

            <thead>

                <tr>
                    <td class="text-center bluelightShade">Grade Wise</td>
                    <td class="text-center blue-light">Total Nos.</td>
                    <td class="text-center bluelightShade">Current Org distribution %</td>
                    <td class="text-center blue-light">Promotion %</td>
                    <td class="text-center bluelightShade">Ideal Nos.</td>
                    <td class="text-center blue-light">Promotion <br />Reco. Received</td>
                    <td class="text-center bluelightShade">Ratio</td>
                    <td class="text-center blue-light">Difference</td>
                    <td class="text-center bluelightShade">Final Approved</td>
                    <td class="text-center blue-light">Final Approved %</td>
                </tr>
            </thead>
            <tbody></tbody>
        </table>


        <div class="norm-doc-download-top" style="margin-bottom:10px;">
            <div class="norm-doc-download">
                <div style="text-align: left;">
                    <h5 class="reprt-heading-title"><b>Gender Promotion Summary Details</b></h5>
                </div>
                <a class="form-control" style="width:122px;" onclick="tableToExcel('tblHRBPAdminMFPromotionSummary', 'Male/Female Promotion Summary Details', 'BtnAdminMFPromotionSummary')" id="BtnAdminMFPromotionSummary">
                    <i class="fa fa-file-excel-o"></i>
                </a>

            </div>
        </div>

        <table id="tblHRBPAdminMFPromotionSummary" class="table table-striped table-bordered nowrap data-table-main" style="width:100%">


            <tbody>
                <tr>
                    <td class="text-center bluelightShade"></td>
                    <td colspan="6" class="text-center blue-light">Male</td>
                    <td colspan="6" class="text-center bluelightShade">Female</td>
                    <td colspan="6" class="text-center blue-light">Others</td>
                </tr>
                <tr>
                    <td class="bluelightShade">Grade Wise</td>
                    <td class="text-center blue-light">Total Male</td>
                    <td class="text-center blue-light">Current Org  distribution</td>

                    <td class="text-center blue-light">Promotion Reco. Received</td>
                    <td class="blue-light">Ratio</td>
                    <td class="blue-light">Final Approved</td>
                    <td class="blue-light">Final Approved %</td>

                    <td class="bluelightShade">Total Female</td>
                    <td class="text-center bluelightShade">Current Org  distribution</td>

                    <td class="text-center bluelightShade">Promotion Reco. Received</td>
                    <td class="bluelightShade">Ratio</td>
                    <td class="bluelightShade">Final Approved</td>
                    <td class="bluelightShade">Final Approved %</td>

                    <td class="blue-light">Total Others</td>
                    <td class="text-center blue-light">Current Org  distribution</td>

                    <td class="text-center blue-light">Promotion Reco. Received</td>
                    <td class="blue-light">Ratio</td>
                    <td class="blue-light">Final Approved</td>
                    <td class="blue-light">Final Approved %</td>
                </tr>

            </tbody>
        </table>


        <div id="hrbpAdmin_prom_chart" style="margin-top:20px;"></div>
    </div>
</div>

