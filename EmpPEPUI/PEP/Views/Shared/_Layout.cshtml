    <script>
        // Remove sidebar page loader on page load
        $(window).on('load', function() {
            $('#sidebar-page-loader').remove();
        });
        
        $(document).ready(function () {
            // Remove sidebar page loader immediately on ready
            $('#sidebar-page-loader').remove();
            
            $('[data-toggle="tooltip"]').tooltip();
            $('.sidebar-menu ul li a').on('click', function () {
                $('.sidebar-menu li a').removeClass('current');
                $(this).addClass('current');
            });
            $('.sidebar ul li a').on('click', function () {
                $('.sidebar ul li a.current').removeClass('current');
                $(this).addClass('current');
            });
            $(".openbtn").click(function () {
                $(".main-content-right").addClass("fixed-content-sec");
            });
            $(".closebtn").click(function () {
                $(".main-content-right").removeClass("fixed-content-sec");
            });
        });
        function openNav() {
            document.getElementById("mySidebar").style.width = "250px";
            document.getElementById("top-main").style.paddingLeft = "250px";
        }

        function closeNav() {
            document.getElementById("mySidebar").style.width = "0";
            document.getElementById("top-main").style.paddingLeft = "15px";
        }
    </script>
</body>
</html>
