<!-- Criticality Details Modal -->
<div id="criticalityDetailsModal" class="modal bs-modal-lg fade modal-popup" data-backdrop="static" role="dialog" style="z-index: 1050;">
    <div class="modal-dialog modal-lg" style="width:900px;">
        <div class="modal-content">
            <div class="modal-header" style="padding:10px 10px !important">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">Criticality Details</h4>
            </div>
            <div class="modal-body modal-scrollable" style="padding:15px !important">
                <!-- Loader inside modal -->
                <div id="criticalityModalLoader" style="text-align: center; padding: 40px; display: none;">
                    <i class="fa fa-spinner fa-spin" style="font-size: 48px; color: #4986f1;"></i>
                    <h4 style="margin-top: 20px;">Loading Criticality Details...</h4>
                    <p style="color: #666; margin-top: 10px;">Please wait while we fetch the data.</p>
                </div>

                <!-- Modal Content (hidden initially) -->
                <div id="criticalityModalContent" style="display: none;">
                    <!-- Basic Employee Details -->
                    <div class="row" style="margin-bottom: 15px; padding: 10px; background-color: #f5f5f5; border-radius: 4px;">
                        <div class="col-md-12">
                            <div class="row">
                                <div class="col-md-4">
                                    <label><strong>Name:</strong></label>
                                    <span id="modalEmployeeName"></span>
                                </div>
                                <div class="col-md-4">
                                    <label><strong>Location:</strong></label>
                                    <span id="modalEmployeeLocation"></span>
                                </div>
                                <div class="col-md-4">
                                    <label><strong>Grade:</strong></label>
                                    <span id="modalEmployeeGrade"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <form id="criticalityDetailsForm">
                        <p style="font-size: 14px; color: #333; margin-bottom: 15px;">Please indicate the critical talent in your span. This should not exceed 25% of the entire span rolling into you.</p>
                        <p id="prioritisationText" style="display: none; font-size: 14px; color: #333; margin-bottom: 15px;">Also, kindly prioritise your talent into P1, P2 and P3 covering not more than 5%, 5% and 15% of your span respectively.</p>
                        <input type="hidden" id="modalPEPEmployeeId" />
                        <input type="hidden" id="modalAppraisalCycleId" />

                        <!-- Row 1: Criticality Reasons and Criticality Priority -->
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group multiselectddl">
                                    <label for="ddlCriticalityReasons"><strong>Criticality Reasons (Max 2 Selections)</strong> <span style="color: red;">*</span></label>
                                    <select class="form-control" id="ddlCriticalityReasons" multiple="multiple" style="width: 100%;">
                                        <!-- Options will be loaded from database -->
                                    </select>
                                    <small class="text-muted">Select maximum 2 reasons</small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="ddlCriticalityPriority">
                                        <strong>Criticality Priority (Top 25% Talent)</strong> <span style="color: red;">*</span>
                                    </label>
                                    <select class="form-control" id="ddlCriticalityPriority" style="width: 100%;">
                                        <option value="">--Select--</option>
                                        <!-- Options will be loaded from database -->
                                    </select>
                                    <small class="text-muted">Cannot exceed 25% of total span</small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label for="ddlAttritionRisk"><strong>Attrition Risk</strong> <span style="color: red;">*</span></label>
                                    <select class="form-control" id="ddlAttritionRisk" style="width: 100%;">
                                        <option value="">--Select--</option>
                                        <!-- Options will be loaded from database -->
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Row 2: Immediate Backup Name and Successor Name -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="ddlImmediateBackup"><strong>Immediate Backup Name</strong> <span style="color: red;">*</span></label>
                                    <select class="form-control" id="ddlImmediateBackup" style="width: 100%;">
                                        <option value="">--Select Employee--</option>
                                        <!-- Options will be loaded from employee span -->
                                    </select>
                                    <small class="text-muted">Name of immediate backup if the critical employee exits</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="ddlSuccessorName"><strong>Successor Name (Long Term)</strong> <span style="color: red;">*</span></label>
                                    <select class="form-control" id="ddlSuccessorName" style="width: 100%;">
                                        <option value="">--Select Employee--</option>
                                        <!-- Options will be loaded from employee span -->
                                    </select>
                                    <small class="text-muted">Name of eventual successor to the employee in the long term</small>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <div class="modal-footer" style="padding:10px 18px !important">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSaveCriticalityDetails" style="display: none;">Save</button>
            </div>
        </div>
    </div>
</div>


