            <div class="col-md-12 tblEmpRating-List">
                <table class="table tbl-my-team-kra datatable table-borderd" width="100%" id="tblApprovedReporteeList">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Gender</th>
                            <th>Grade</th>
                            <th>Location</th>
                            <th>Group Account</th>
                            <th>Total <br />Exp.</th>
