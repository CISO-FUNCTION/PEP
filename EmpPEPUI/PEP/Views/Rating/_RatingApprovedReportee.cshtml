    <div class="container-fluid">
        @*class="modal fade" role="dialog"*@

        <div id="ViewNTHistoryDetails" class="modal  bs-modal-lg fade modal-popup" role="dialog">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                        <h4 class="modal-title">Action History</h4>
                    </div>
                    <div class="modal-body modal-scrollable">
                        <div class="row">
                            <div class="col-sm-12">
                                <table id="tblActionHistory" class="table table-bordered table-hover blue" style="width:100%">
                                    <thead>
                                        <tr>
                                            <th style="min-width:35px;">S.No.</th>
                                            <th>Approver</th>
                                            <th>Rating</th>
                                            <th>Given Date</th>
                                            <th>Action</th>
                                            <th>Comment</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">

            <div class="row" style="position: relative" id="divFiltersRAR">
                <div class="col-md-12">
                    <div class="filter-img-sec">
                        <button title="Filter" id="open-filterRAR"><span class="glyphicon glyphicon-filter"></span></button>
                        <button id="close-filterRAR"><span class="glyphicon glyphicon-remove"></span></button>
                    </div>
                </div>
                <div class="col-md-12 filter-top-sec-item">
                    <h5 class="reprt-heading-title" style="color: #696a6b; font-size:12px"><b>Filters</b></h5>
                    <div id="filtersDropDiv" style="display:block;">
                        <div class="row">
                            <div class="col-md-2">
                                <label id="reporteeDDL_RAR" class="ReporteeOFRM filterAttr" style="font-size:11px">
                                    <span class="text-label">My Span</span>
                                    <span><select class="form-control" multiple="multiple" id="ddlReportee_RAR"></select></span>
                                </label>
                            </div>
                            <div class="col-md-2">
                                <label id="gradeDDL_RAR" class="Grade filterAttr" style="font-size:11px">
                                    <span class="text-label">Grade</span>
                                    <span><select class="form-control" multiple="multiple" id="ddlgrade_RAR"><option value="0">--select--</option></select></span>
                                </label>
                            </div>
                            <div class="col-md-2">
                                <label id="location_RAR" class="Location filterAttr" style="font-size:11px">
                                    <span class="text-label">Location</span>
                                    <span><select class="form-control" multiple="multiple" id="ddllocation_RAR"><option value="1">India</option><option value="3">US</option><option value="2">ROW</option></select></span>
                                </label>
                            </div>
                            <div class="col-md-2">
                                <label id="" class="GroupAccount filterAttr" style="font-size:11px;">
                                    <span class="text-label">Group Account</span>
                                    <span><select class="form-control" multiple="multiple" id="ddlgroupaccount_RAR"><option value="0">--select--</option></select></span>
                                </label>
                            </div>
                            <div class="col-md-2">
                                <label id="" class="Gender filterAttr" style="font-size:11px;">
                                    <span class="text-label">Gender</span>
                                    <span><select class="form-control" multiple="multiple" id="ddlgender_RAR"><option value="Male">Male</option><option value="Female">Female</option></select></span>
                                </label>
                            </div>
                            <div class="col-md-2">
                                <label id="" class="GroupAccount filterAttr" style="font-size:11px;">
                                    <span class="text-label">Employee Status</span>
                                    <span><select class="form-control" multiple="multiple" id="ddlEmployeeStatus_RAR"><option value="0">--select--</option></select></span>
                                </label>
                            </div>
                        </div>
                    </div>


                    <div id="filtersApprovedReportee" style="display:none;">
                        <div class="rating-summery">
                            <div class="rating-summery-inn">

                                <button class="abc" onclick="filterData('EE1','tblApprovedReporteeList');"><span id="filteronclick" class="MR_filterEE1">EE-Exceeds Expectations(5%) - [<span id="RM_EE1span">EE1</span>]</span></button>
                                <button class="abc" onclick="filterData('EE', 'tblApprovedReporteeList');"><span id="filteronclick" class="MR_filterEE">EE-Exceeds Expectations(25)% - [<span id="RM_EEspan">EE</span>]</span></button>
                                <button class="abc" onclick="filterData('ME', 'tblApprovedReporteeList');"><span id="filteronclick" class="MR_filterME">ME-Meets Expectations(60%) - [<span id="RM_MEspan">ME</span>]</span></button>
                                <button class="abc" onclick="filterData('BE', 'tblApprovedReporteeList');"><span id="filteronclick" class="MR_filterBE"> BE-Below Expectations(10%) - [<span id="RM_BEspan">BE</span>]</span></button>
                                <button class="abc" onclick="filterData('RM', 'tblApprovedReporteeList');"><span id="filteronclick" class="MR_RM">My Reportees- [<span id="MyReporteeCount"></span>]</span></button>
                                <button class="abc" onclick="filterData('Total', 'tblApprovedReporteeList');"><span id="filteronclick" class="MR_Total">Reset</span></button>

                            </div>
                        </div>
                    </div>

                </div>

            </div>

