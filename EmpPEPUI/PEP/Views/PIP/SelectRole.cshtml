@{
    ViewBag.Title = "SelectRole";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    div#PIPSelectRole label.control-label {
        padding: 0px;
        margin-right: 10px;
    }

    div#PIPSelectRole {
        padding: 0px 30px 0px;
        margin-top: 10px;
    }

        div#PIPSelectRole #ddlEmpRole {
            width: 64% !important;
        }
</style>

@{
    Response.Cache.SetCacheability(HttpCacheability.NoCache);
    Response.Cache.SetNoStore();
}
<div class="container-fluid">
    <div class="row">
        <div id="PIPSelectRole" class="col-sm-6">
            <div id="divSelectEmpRole">
                <div class="form-horizontal">
                    <div class="form-group" style="padding-bottom:15px;display:flex;align-items:center;">
                        <label class="control-label">Select your Role:</label>
                        <select id="ddlEmpRole" class="ddlMgrList form-control"></select>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<script type="text/javascript">

    $(document).ready(function () {

        debugger;
        if (performance.navigation.type === 2) {
            location.reload(true);
        }

        if ((sessionStorage.LocationId == '3' || sessionStorage.LocationId == '75') && sessionStorage.IsHRBP == false) {

            window.location.href = '/Error/NotAuthorized';
        }
        BindRoleList();
        //$('#ddlEmpRole').val(0);

    });

    $('#ddlEmpRole').on('change', function () {

        $.post('@Url.Action("PIPRoleView", "PIP")', { RoleId: $('#ddlEmpRole').val() }, function (data) {

            window.location.href = data.redirectTo;
        });

    });

    function BindRoleList() {

        var svrPath = CONFIG.get('SERVERNAME');
        var apiPath1 = svrPath + "PIP/GetEmpRoleListById?EmpID=" + sessionStorage.EmployeeId

        var ddlId = $("#ddlEmpRole");
        var columns = [];

        $.ajax({
            contentType: 'application/json; charset=utf-8',
            dataType: 'json',
            type: 'Get',
            url: apiPath1,
            async: false,
            success: function (result) {

                debugger;
                $(ddlId).empty();
                var name = "";
                var newOption = "";

                newOption = '<option value="0">--Select--</option>';
                $(ddlId).append(newOption);


                $.each(result.Result.data, function (i, data) {
                    // bind the dropdown list using json result
                    $('<option>',
                       {
                           value: data.RoleId,
                           text: data.RoleName
                       }).html(data.RoleName).appendTo(ddlId);
                });


            }
        })


    }


</script>

@section scripts{

    <link href="~/Content/toastr.min.css" rel="stylesheet" />
    <script src="~/Scripts/PEPScripts/toastr.min.js"></script>
    <script src="~/Scripts/jquery-ui-1.12.1.js"></script>
    <script src="~/Scripts/DataTables/jquery.dataTables.min.js"></script>
    <link href="~/Content/DataTables/css/jquery.dataTables.min.css" rel="stylesheet" />
    <script src="~/Scripts/PEPScripts/Common.js"></script>
    <script src="~/Scripts/PEPScripts/CommonConfig.js"></script>
    <script src="~/Scripts/PEPScripts/loader.js"></script>

    <script src="~/Scripts/PEPScripts/select2.min.js"></script>
    <link href="~/Scripts/PEPScripts/select2.min.css" rel="stylesheet" />
    <link href="~/Scripts/PEPScripts/bootstrap-multiselect.css" rel="stylesheet" />
    <script src="~/Scripts/PEPScripts/bootstrap-multiselect.min.js"></script>


}
