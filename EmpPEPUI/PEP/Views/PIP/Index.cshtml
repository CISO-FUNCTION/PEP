                    <div class="col-sm-12">
                        <div class="form-group">
                            <p>
                                <b>
                                    Note: Please upload emails that may have been sent to the employee giving him/ her feedback on the performance issues. You may upload more than one file by holding down the Ctrl key while selecting files.
                                </b>
                            </p>

                        </div>
                    </div>
                </div>
                <div class="row">

                    <div class="col-md-6">
                        <div class="form-group">
                            <span class="text-label"><b>Employee Name :</b> </span>
                            <label class="text-label" id="txtSelectEmployeeName" name="txtSelectEmployeeName"></label>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">

                            <label>Attachment :<span class="string-red">*<span><i class='fa fa-paperclip' style='color:Grey' aria-hidden='true'></i> file attached : </span></span> </label>
                            <a class='downloadfile' href="#"><label id="filename"></label></a>
                            <span class="attachment-text">You may attach more than one file by holding down the Ctrl key while selecting files.</span>


                            <div class="attachebilefile">
                                <input type="file" name="img[]" class="file" id="uploadDocfile" multiple="multiple">
