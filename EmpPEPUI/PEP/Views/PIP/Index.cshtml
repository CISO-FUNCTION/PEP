                                    <div class="input-group-addon">
                                        <span class="" id="basic-addon1"><i class="fas fa-paperclip"></i></span>
                                    </div>
                                    <input type="text" class="form-control" id="txtAttachedDoc" disabled placeholder="Upload File"
                                           aria-label="Upload File" aria-describedby="basic-addon1">
                                    <div class="input-group-btn">
                                        <button type="button" class="browse btn btn-primary" id="basic-addon2">
                                            <i class="fas fa-search"></i> Browse
                                        </button>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                <div class="row">

                    <div class="col-md-7">
                        <div class="form-group">
                            <span class="text-label"><b>PIP Reason :</b><span class="string-red">*</span> </span>
                            <span id="txtReasonRemaining"></span>

