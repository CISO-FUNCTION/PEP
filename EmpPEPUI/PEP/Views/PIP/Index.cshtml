@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@{

    var RoleId = "0";

    if (((Session["RoleId"])) != null)
    {
        RoleId = ((Session["RoleId"])).ToString();

        //  @ViewBag.AccessType= AccessType;
    }
}
<script type="text/javascript">

    var SelectionRoleId= @RoleId.ToString();

    if(sessionStorage.IsRM=='false' && sessionStorage.IsHRBP=='false')
    {
        SelectionRoleId= 1;
    }


    if(SelectionRoleId==1)
    {
        $('#RoleName').text('Employee');

    }else if(SelectionRoleId==2)
    {
        $('#RoleName').text('Reporting Manager');
    }
    else if(SelectionRoleId==3)
    {
        $('#RoleName').text('Skip Reporting Manager');
    }else if(SelectionRoleId==4)
    {
        $('#RoleName').text('HRBP');
    }

</script>
<div class="container-fluid">


    <div class="row" id="roleDiv">

        <div class="col-md-6">
            <div class="form-group">

                <h5 class="divAlert">
                    <span>Role :</span> <span id="RoleName"></span>
                </h5>

            </div>
        </div>

    </div>


    <div id="PIPReporteeDDLDiv" class="row border-sec" style="display:none;">

        <div class="col-md-6">
            <div class="form-horizontal">
                <div class="form-group" style="display:flex;align-items:center;">
                    <label class="control-label">Select Reportees to Initiate PIP:</label>
                    <select id="ddlAspireReportee" class="ddlMgrList form-control"></select>
                </div>
            </div>

        </div>

        <div style="display:none;" id="divSEmpID" class="col-md-12">
            <div class="tblEmpRating-List" style="margin-top: 18px;">
                <table class="table tbl-my-team-kra datatable table-borderd" id="tblSelectEmpPIPList">
                    <thead>
                        <tr>
                            <th>Employee Name</th>
                            <th>Grade</th>
                            <th>Project</th>
                            <th>PIP Reason</th>

                            <th>Initiate PIP</th>

                            <th>PIP Start Date</th>
                            <th>PIP End Date</th>

                            <th>PIP Status</th>
                            <th>PIP Supporting Doc</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>

    </div>
    <div class="row border-sec">
        <div id="PIPFilterDiv" class="col-md-12" style="display:none;">

            <div class="row">

                <div class="col-md-4">

                    <div class="form-horizontal">
                        <div class="form-group" style="display:flex;align-items:center;">
                            <label class="control-label">Select filter :</label>
                            <select class="form-control" id="ddlFilter">

                                <option value="1">PIPs initiated by me</option>
                                <option value="2">PIPs in my span</option>

                            </select>
                        </div>
                    </div>

                </div>

            </div>

        </div>


        <div class="col-md-12 tblEmpRating-List" style="margin-top: 18px;">
            <table class="table tbl-my-team-kra datatable table-borderd" width="100%" id="tblEmpPIPList">
                <thead>
                    <tr>
                        <th class="PIPAction">Action History</th>
                        <th>Employee Name</th>
                        <th>Grade</th>
                        <th>Project</th>
                        <th>PIP Remarks</th>
                        <th>PIP Start Date</th>
                        <th>PIP End Date</th>
                        <th>PIP Status</th>
                        <th class="PIPDoc">PIP Supporting Doc</th>
                        <th>Action</th>

                    </tr>
                </thead>
            </table>
        </div>
    </div>

</div>


<div id="ViewHistoryDetails" class="modal fade" role="dialog">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Action History</h4>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body modal-scrollable">
                <div class="row">
                    <div class="col-sm-12">
                        <table id="tblActionHistory" class="table table-bordered table-hover blue" style="width:100%">
                            <thead>
                                <tr class="thead-bg-blue">
                                    <th style="min-width:35px;">S.No.</th>
                                    <th>Action Taken</th>
                                    <th>Action By</th>
                                    <th>Action On</th>
                                    <th>Status From</th>
                                    <th>Status To</th>
                                    <th>Remarks</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div id="addPIPDoc" class="modal fade popup" role="dialog">

