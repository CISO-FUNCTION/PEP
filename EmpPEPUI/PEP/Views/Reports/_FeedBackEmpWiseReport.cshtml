<div class="row" id="divFBReportEmpWise">
    <div class="col-sm-5" id="divSelectEmpFB">
        <div class="form-horizontal">
            <div class="form-group" style="padding-bottom:15px;">
                <label class="col-sm-4 control-label">Select Employee :</label>
                <div class="col-sm-8">
                    <select id="ddlEmpListForfeedback" class="ddlMgrList form-control"></select>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="form-horizontal">
            <div class="form-group" style="padding-bottom:15px;">
                <label class="col-md-4 control-label">Select Type :</label>
                <div class="col-md-8">
                    <select id="ddlFBStatus" class="form-control">
                        <option value="FBKNC">Manager Feedback (G&Os)</option>
                        <option value="FBGIVEN">Feedback Given</option>
                        <option value="FBREQUEST">Feedback Requested</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-5">
        <div class="form-horizontal">
            <div class="form-group">
                <label class="col-sm-4 control-label">Start :</label>
                <div class="col-sm-8">
                    <input class="input-exitSmall form-control KRADatePicks" id="dtFromFBEmpReport" />
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-5">
        <div class="form-horizontal">
            <div class="form-group">
                <label class="col-sm-4 control-label">End :</label>
                <div class="col-sm-8">
                    <input class="input-exitSmall form-control KRADatePicks" id="dtToFBEmpReport" />
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-12 form-group pdtop15">
        <input type="button" value="View Report" class="btn btn-primary" id="btnFBEmpReport" />
        <input type="button" value="Export Report" class="btn btn-primary" id="btnExportToExcelFBEmpReport" />
    </div>

    <div class="col-sm-12">
        <table id="tblFBEmpReport" class="table tbl-my-team-kra-beh-comp" style="width: 100%;">
            <thead class="cf">
                <tr>
                    <th>Feedback Date</th>
                    <th>EmployeeName (From)</th>
                    <th>EmployeeCode (From)</th>
                    <th>EmployeeName (To)</th>
                    <th>EmployeeCode (To)</th>
                    <th>Area</th>
                    <th>KRA</th>
                    <th>KPIs</th>
                    <th>Action Plan</th>
                    <th>Weightage</th>
                    <th>Rating</th>
                    <th>Feedback</th>
                </tr>
            </thead>
        </table>
    </div>
</div>
