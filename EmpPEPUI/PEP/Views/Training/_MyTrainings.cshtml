@using EmpPEP.UI.Views.Training;
<div class="row">
    <div class="col-lg-12">
        <div class="table-responsive">
            <table id="tblMyTrainingList" cellspacing="0" width="100%" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th class="col-md-1">@Training.TrainingType</th>
                        <th class="col-md-2">@Training.TrainingName</th>
                        <th class="col-md-2">@Training.FromDate</th>
                        <th class="col-md-1">@Training.ToDate</th>
                        <th class="col-md-2">@Training.Status</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>