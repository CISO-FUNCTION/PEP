        <link href="~/Content/DataTables/css/jquery.dataTables.min.css" rel="stylesheet" />*@
    @*<script src="~/Scripts/jquery-ui-1.8.24.min.js"></script>*@
    <script src="~/Scripts/PEPScripts/Common.js"></script>
    <script src="~/Scripts/PEPScripts/CommonConfig.js"></script>
    <script src="~/Scripts/PEPScripts/EmployeeLoginInfo.js"></script>
    <script src="~/Scripts/PEPScripts/AdminMain.js"></script>
    <script src="~/Scripts/PEPScripts/MasterOperations.js"></script>
    <script src="~/Scripts/PEPScripts/GradeAreaCompentecyMapping.js"></script>
    <link href="~/Scripts/PEPScripts/bootstrap-multiselect.css" rel="stylesheet" />
    <script src="~/Scripts/PEPScripts/bootstrap-multiselect.min.js"></script>
    <script src="~/Scripts/PEPScripts/Ratings.js"></script>
    <script src="~/Scripts/PEPScripts/UploadKRAMaster.js"></script>
    <script src="~/Scripts/PEPScripts/SelfAssessmentCycleMaster.js"></script>
    <script type="text/javascript">
        function RemoveScript(id) {
            debugger;
            var txtValue = $('#' + id).val();
            $('#' + id).val(txtValue.replace(/[\<\>'=]+/g, ''));
        }
    </script>
}

