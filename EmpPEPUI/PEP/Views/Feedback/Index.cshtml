<style>
    #dvMyKraContent .dataTables_scrollBody {
        height: 100% !important;
    }
    #feedbackPageLoadingOverlay {
        display: none;
        position: fixed;
        left: 53px;
        top: 60px;
        right: 0;
        bottom: 0;
        z-index: 2000;
        background: rgba(255, 255, 255, 0.72);
        -webkit-backdrop-filter: blur(2px);
        backdrop-filter: blur(2px);
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }
    .feedback-loading-inner {
        text-align: center;
        padding: 24px 32px;
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 4px 24px rgba(0,0,0,.12);
        min-width: 200px;
    }
    .feedback-loading-spinner {
        display: inline-block;
        width: 40px;
        height: 40px;
        border: 3px solid #e8e8e8;
        border-top-color: #337ab7;
        border-radius: 50%;
        animation: feedback-spin 0.75s linear infinite;
        margin-bottom: 12px;
        vertical-align: middle;
    }
    .feedback-loading-text {
        display: block;
        font-size: 14px;
        color: #555;
        font-weight: 500;
    }
    @@keyframes feedback-spin {
        to { transform: rotate(360deg); }
    }
</style>
<div id="feedbackPageLoadingOverlay" class="feedback-page-loading-overlay" aria-live="polite" aria-busy="false">
    <div class="feedback-loading-inner">
        <span class="feedback-loading-spinner" role="status"></span>
        <span class="feedback-loading-text">Loading...</span>
    </div>
</div>
