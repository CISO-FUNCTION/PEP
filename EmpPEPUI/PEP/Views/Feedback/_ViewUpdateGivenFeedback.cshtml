@{
    ViewBag.Title = "ViewGivenFeedback";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<link href="~/Content/themes/base/jquery-ui.css" rel="stylesheet" />

<script>
    var GToEmployeeId = @ViewBag.EmployeeID;
    var GToYearCycle = @ViewBag.YearCycle;
    var DashValue1 = @ViewBag.DashboardValue;
    var ddlAppCycleId = "@ViewBag.AppraisalCycleId";

</script>
<style>
    #giveFeedbackLoader {
        position: fixed;
        top: 60px;
        left: 53px;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.72);
        -webkit-backdrop-filter: blur(2px);
        backdrop-filter: blur(2px);
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    #giveFeedbackLoader .loader-content {
        text-align: center;
        padding: 24px 32px;
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 4px 24px rgba(0,0,0,.12);
        min-width: 200px;
    }

    #giveFeedbackLoader .loader-content span {
        display: block;
        font-size: 14px;
        color: #555;
        font-weight: 500;
    }

    @@keyframes giveFbSpin {
        to { transform: rotate(360deg); }
    }
</style>

<div id="giveFeedbackLoader" style="display: flex;">
    <div class="loader-content">
        <span style="display: inline-block; width: 40px; height: 40px; border: 3px solid #e8e8e8; border-top-color: #337ab7; border-radius: 50%; animation: giveFbSpin 0.75s linear infinite; margin-bottom: 12px;"></span>
        <span>Loading Feedback...</span>
    </div>
</div>

<div id="main-wrapper">
    <div id="main">
        <div class="row pg-main-title">
            <div class="col-12 pg-title-border"><h4><b>FEEDBACK</b></h4></div>
        </div>
        @{
            <div>
                <select class="form-control" style="width:20%;margin-top: 15px;" id="ddlyear"></select>
            </div>
        }
        <ul class="nav nav-tabs" id="SinglefeedbackTabs">
            <li id="" class="active"><a href="#tab_feedbackgivenView" data-toggle="tab">Feedback Given</a></li>
        </ul>
        <a href="#" id="lnkViewRRAndTraining" class="btn btn-info" style="margin-left: 15px;float:right;" data-toggle="modal" data-target="#modalRRAndTraining">
            <i class="glyphicon glyphicon-list-alt"></i> View Recognition Received / Training Status
        </a>



        <div class="tab-pane" id="tab_feedbackgivenView">
            <div class="panel-group" id="accordion1">
                <div class="panel panel-default" id="pnlKRAFeedbackGivenDashoard">
                    <div class="panel-heading">
                        <h4 class="panel-title">
                            <a data-toggle="collapse" data-target="#collapseFour" href="#collapseFour" data-parent="#accordion1">
                                Goals & Objectives
                            </a>
                        </h4>
                    </div>
                    <div id="collapseFour" class="panel-collapse collapse in">
                        <div class="panel-body" id="dvMyKraContent">
                            @{Html.RenderPartial("_FeedbackGivenKRA");}
                        </div>
                        @*<div id="AddManagersEditFeedbackBC" class="panel-body">@Html.Partial("../Feedback/_AddEditManagerFeedbackKRA")</div>*@
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

<input type="hidden" id="hdnSelectedFeedbackTab" />

<!-- R&R and Training Status Modal -->
<div class="modal fade" role="dialog" id="modalRRAndTraining" tabindex="-1">
    <div class="modal-dialog modal-lg" role="document" style="width: 90%; max-width: 1200px;">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title">Trainings / Recognitions </h4>
            </div>
            <div class="modal-body">
                <ul class="nav nav-tabs" role="tablist">
                    <li role="presentation" class="active">
                        <a href="#tabTrainingStatusGiven" aria-controls="tabTrainingStatusGiven" role="tab" data-toggle="tab">Trainings</a>
                    </li>
                    <li role="presentation">
                        <a href="#tabRRGiven" aria-controls="tabRRGiven" role="tab" data-toggle="tab">Recognition Received</a>
                    </li>
                </ul>
                <div class="tab-content" style="margin-top: 15px;">
                    <div role="tabpanel" class="tab-pane active" id="tabTrainingStatusGiven">
                        <table class="table table-striped table-bordered" id="tblTrainingStatusListGiven" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Training Type</th>
                                    <th>Training Name</th>
                                    <th>Progress Percentage</th>
                                    <th>Learning Status</th>
                                    <th>Requested From</th>
                                    <th>Created Date</th>
                                    <th>Completion Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td colspan="7" style="text-align:center; padding:20px;">No data available</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div role="tabpanel" class="tab-pane" id="tabRRGiven">
                        <table class="table table-striped table-bordered" id="tblRRListGiven" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Sr. No.</th>
                                    <th>Award Name</th>
                                    <th>Award Type</th>
                                    <th>Award Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td colspan="4" style="text-align:center; padding:20px;">No data available</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" role="dialog" id="feedbackModal" data-url="@Url.Action("GetFeedbackModal")">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title">Feedback</h4>
            </div>
            <div class="modal-body">
                <div id="feedbackContent">
                </div>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->
@section scripts{

    <link href="~/Content/toastr.min.css" rel="stylesheet" />
    <link href="~/Content/DataTables/css/jquery.dataTables.min.css" rel="stylesheet" />
    <script src="~/Scripts/PEPScripts/toastr.min.js"></script>
    <script src="~/Scripts/DataTables/jquery.dataTables.min.js"></script>
    <script src="~/Scripts/PEPScripts/FeedbackConsolidatedTraining.js"></script>
    <script src="~/Scripts/PEPScripts/Feedback.js"></script>

}
