@*@{
        Layout = "~/Views/Shared/_Layout.cshtml";
    }*@


<script>

    var GToEmployeeId = @ViewBag.EmployeeId;
    var Gselectedyear=@ViewBag.selectedyear;
    var DashboardValue = @ViewBag.DashboardValue;
    var ddlAppCycleId = @ViewBag.ddlAppCycleId;

</script>


<style type="text/css">
    .csstxtarea {
        width: 100%;
        border: 2px solid #e51313 !important;
    }
    /* Full-screen loader for Manager Feedback (goals + previous RM data) */
    #managerFeedbackPageLoader {
        display: none;
        position: fixed;
        top: 60px;
        left: 53px;
        right: 0;
        bottom: 0;
        z-index: 2000;
        background: rgba(255, 255, 255, 0.72);
        -webkit-backdrop-filter: blur(2px);
        backdrop-filter: blur(2px);
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }
    #managerFeedbackPageLoader .mf-loader-inner {
        text-align: center;
        padding: 24px 32px;
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 4px 24px rgba(0,0,0,.12);
        min-width: 200px;
    }
    #managerFeedbackPageLoader .mf-loader-spinner {
        display: inline-block;
        width: 40px;
        height: 40px;
        border: 3px solid #e8e8e8;
        border-top-color: #337ab7;
        border-radius: 50%;
        animation: mf-spin 0.75s linear infinite;
        margin-bottom: 12px;
    }
    #managerFeedbackPageLoader .mf-loader-text {
        display: block;
        font-size: 14px;
        color: #555;
        font-weight: 500;
    }
    @@keyframes mf-spin {
        to { transform: rotate(360deg); }
    }

    .select2-container--open {
        z-index: 9999 !important;
    }
    .select2-dropdown {
        z-index: 9999 !important;
    }
</style>

<div id="managerFeedbackPageLoader" aria-live="polite" aria-busy="true">
    <div class="mf-loader-inner">
        <span class="mf-loader-spinner" role="status"></span>
        <span class="mf-loader-text">Loading...</span>
    </div>
</div>

<div id="main">
    @{
        <div>
            <select class="form-control" style="display:none;width:20%;margin-top: 15px;" id="ddlyearFeedback"></select>
        </div>

    }
    <div class="row">
        <div class="col-md-12">
            <p id="EmployeeName" class="bg-primary heading-strip">
                <span class="glyphicon glyphicon-user"></span>
                @ViewBag.EmployeeName
            </p>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 15px;">
                <ul class="nav nav-tabs" id="feedbackTabs" style="margin-bottom: 0;">
                    <li class="active"><a href="#tab_b" data-toggle="tab">Goals & Objectives</a></li>

                    @*Commented for hide behavioural competencies start*@
                    <li><a href="#tab_a" data-toggle="tab" style="display:none">Behavioural Competency</a></li>
                    @*Commented for hide behavioural competencies end*@

                    <li><a id="aPreviousRMFeedback" href="#tab_c" data-toggle="tab" style="display:none">Previous RM's Feedback</a></li>
                </ul>
                <a href="javascript:void(0);" id="lnkViewRRAndTraining" class="btn btn-info" style="margin-left: 15px;">
                    <i class="glyphicon glyphicon-list-alt"></i> View Recognition Received / Training Status
                </a>
            </div>
            <div class="tab-content">
                <div class="tab-pane active" id="tab_b">
                    <div id="AddManagersFeedbackKRA" style="margin-bottom: 60px;">@Html.Partial("../Feedback/_AddManagersFeedbackKRA_Cards")</div>
                </div>
                @*<div class="tab-pane " id="tab_a">
                        <div id="AddManagersFeedbackBC">@Html.Partial("../Feedback/_AddManagersFeedbackBC")</div>
                    </div>*@
                <div class="tab-pane" id="tab_c">
                    <div id="LastRMFeedback">@Html.Partial("../Feedback/_LastRMFeedback")</div>
                </div>
            </div>
        </div>

    </div>
</div>


<div class="modal fade" role="dialog" id="feedbackOtherModal" data-url="@Url.Action("GetViewOtherFeedbackModal",1)">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title">View Free Text Feedback</h4>
            </div>
            <div class="modal-body">
                <div id="feedbackOtherContent">
                </div>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->

<!-- R&R and Training Status Modal -->
<div class="modal fade" role="dialog" id="modalRRAndTraining" tabindex="-1">
    <div class="modal-dialog modal-lg" role="document" style="width: 90%; max-width: 1200px;">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title">Trainings / Recognitions </h4>
            </div>
            <div class="modal-body">
                <!-- Nav tabs -->
                <ul class="nav nav-tabs" role="tablist">
                    <li role="presentation" class="active">
                        <a href="#tabTrainingStatus" aria-controls="tabTrainingStatus" role="tab" data-toggle="tab">Trainings</a>
                    </li>
                    <li role="presentation">
                        <a href="#tabRR" aria-controls="tabRR" role="tab" data-toggle="tab">Recognition Received</a>
                    </li>

                </ul>

                <!-- Tab panes -->
                <div class="tab-content" style="margin-top: 15px;">
                    <!-- Training Status Tab -->
                    <div role="tabpanel" class="tab-pane active" id="tabTrainingStatus">
                        <table class="table table-striped table-bordered" id="tblTrainingStatusList" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Training Type</th>
                                    <th>Training Name</th>
                                    <th>Progress Percentage</th>
                                    <th>Learning Status</th>
                                    <th>Requested From</th>
                                    <th>Created Date</th>
                                    <th>Completion Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td colspan="7" style="text-align:center; padding:20px;">No data available</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- R&R Tab -->
                    <div role="tabpanel" class="tab-pane" id="tabRR">
                        <table class="table table-striped table-bordered" id="tblRRList" style="width:100%;">
                            <thead>
                                <tr>
                                    <th>Sr. No.</th>
                                    <th>Award Name</th>
                                    <th>Award Type</th>
                                    <th>Award Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td colspan="4" style="text-align:center; padding:20px;">No data available</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->

