<style type="text/css">
    /* Summernote Editor Custom Styling - Override global .btn class */
    .note-editor .note-toolbar {
        background-color: #f5f5f5 !important;
        border-bottom: 1px solid #ddd !important;
    }
    
    /* Override global .btn styling specifically for Summernote editor buttons */
    .note-editor .note-btn-group .note-btn {
        background-color: #e3f2fd !important; /* Light blue background */
        background-image: none !important; /* Remove any inherited gradient */
        border: 1px solid #90caf9 !important; /* Light blue border */
        border-radius: 3px !important; /* Square corners instead of rounded */
        padding: 5px 10px !important;
        color: #1976d2 !important; /* Blue text color */
        transition: all 0.2s ease !important;
        box-shadow: none !important;
    }
    
    .note-editor .note-btn-group .note-btn:hover {
        background-color: #bbdefb !important; /* Slightly darker light blue on hover */
        background-image: none !important;
        border-color: #64b5f6 !important;
        transform: none !important; /* Remove any transform effect */
        box-shadow: none !important;
    }
    
    .note-editor .note-btn-group .note-btn.active,
    .note-editor .note-btn-group .note-btn:active,
    .note-editor .note-btn-group .note-btn:focus {
        background-color: #2196f3 !important;
        background-image: linear-gradient(45deg, #2196f3, #00bcd4) !important;
        border-color: #2196f3 !important;
        color: #fff !important;
        transform: none !important;
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.15) !important;
    }
    
    /* Ensure glyphicons are visible in editor buttons */
    .note-editor .note-btn-group .note-btn .glyphicon,
    .note-editor .note-btn-group .note-btn i {
        display: inline-block !important;
        font-size: 14px !important;
        line-height: 1 !important;
        color: inherit !important;
    }
    
    /* Active state for buttons with icons */
    .note-editor .note-btn-group .note-btn.active .glyphicon,
    .note-editor .note-btn-group .note-btn.active i {
        color: #fff !important;
    }
    
    /* Ensure dropdown toggles in editor also get same styling */
    .note-editor .note-btn-group .dropdown-toggle {
        background-image: none !important;
        border-radius: 3px !important;
    }
    
    .note-editor .note-btn-group .dropdown-toggle:hover,
    .note-editor .note-btn-group .dropdown-toggle:active {
        background-image: linear-gradient(45deg, #2196f3, #00bcd4) !important;
    }
    
    /* Editable area styling */
    .note-editor.note-frame .note-editing-area .note-editable {
        background-color: #fff !important;
        color: #333 !important;
        min-height: 150px !important;
    }
    
    .note-editor.note-frame .note-editing-area .note-editable:focus {
        background-color: #fff !important;
        outline: none !important;
    }
</style>
