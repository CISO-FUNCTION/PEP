@*@{
        Layout = "~/Views/Shared/_Layout.cshtml";
    }*@


<script>

    var DashValue1 = @ViewBag.DashboardValue1;
    var DashboardValue = @ViewBag.DashboardValue;
    var GToEmployeeId = @ViewBag.EmployeeId;
    var Gselectedyear= @ViewBag.selectedyear;
    var ddlAppCycleId = @ViewBag.ddlAppCycleId;

</script>
<link href="~/Content/themes/base/jquery-ui.css" rel="stylesheet" />
<style>
    #feedbackPageLoadingOverlay {
        display: none;
        position: fixed;
        left: 53px;
        top: 60px;
        right: 0;
        bottom: 0;
        z-index: 2000;
        background: rgba(255, 255, 255, 0.72);
        -webkit-backdrop-filter: blur(2px);
        backdrop-filter: blur(2px);
        align-items: center;
        justify-content: center;
        flex-direction: column;
    }
    .feedback-loading-inner {
        text-align: center;
        padding: 24px 32px;
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 4px 24px rgba(0,0,0,.12);
        min-width: 200px;
    }
    .feedback-loading-spinner {
        display: inline-block;
        width: 40px;
        height: 40px;
        border: 3px solid #e8e8e8;
        border-top-color: #337ab7;
        border-radius: 50%;
        animation: feedback-spin 0.75s linear infinite;
        margin-bottom: 12px;
        vertical-align: middle;
    }
    .feedback-loading-text {
        display: block;
        font-size: 14px;
        color: #555;
        font-weight: 500;
    }
    @@keyframes feedback-spin {
        to { transform: rotate(360deg); }
    }
</style>
<div id="feedbackPageLoadingOverlay" class="feedback-page-loading-overlay" aria-live="polite" aria-busy="false">
    <div class="feedback-loading-inner">
        <span class="feedback-loading-spinner" role="status"></span>
        <span class="feedback-loading-text">Loading...</span>
    </div>
</div>
<div id="main-wrapper">
    <div id="main">
        @{
            <div>
                <select class="form-control" style="width:20%;margin-top: 15px;" id="ddlyearSkiplevel"></select>
            </div>

        }
        <div class="row">
            <div class="col-md-12">
                <p id="EmployeeName" class="bg-primary heading-strip">
                    <span class="glyphicon glyphicon-user"></span>
                    @ViewBag.EmployeeName
                </p>
                <ul class="nav nav-tabs" id="feedbackTabsSkipLevel">
                    <li class="active"><a href="#tab_b" data-toggle="tab">Goals & Objectives</a></li>
                    @*
                        <li><a href="#tab_a" data-toggle="tab">Behavioural Competency</a></li>*@

                </ul>
                <div class="tab-content">
                    <div class="tab-pane" id="tab_a">
                        <div class="panel panel-default" id="pnlCompetencyFeedbackGiven">
                            <div class="panel-heading">
                                <h4 class="panel-title">
                                    <a data-toggle="collapse" data-target="#collapseFive" href="#collapseFive" class="collapsed" data-parent="#accordion1">
                                        Competency
                                    </a>
                                </h4>
                            </div>
                            <div id="collapseFive" class="panel-collapse collapse in">
                                <div class="panel-body">
                                    @{Html.RenderPartial("_FeedbackGivenSkipLevelBC");}
                                </div>
                            </div>
                        </div>

                    </div>
                    <div class="tab-pane active" id="tab_b">
                        <div class="panel panel-default" id="pnlKRAFeedbackGiven">
                            <div class="panel-heading">
                                <h4 class="panel-title">
                                    <a data-toggle="collapse" data-target="#collapseFour" href="#collapseFour" data-parent="#accordion1">
                                        Goals & Objectives
                                    </a>
                                </h4>
                            </div>
                            <div id="collapseFour" class="panel-collapse collapse in">
                                <div class="panel-body" id="dvMyKraContent">
                                    @{Html.RenderPartial("_FeedbackGivenSkipLevelKRA");}
                                </div>
                            </div>
                        </div>
                        @*<div id="AddManagersFeedbackKRA">@Html.Partial("../Feedback/_AddManagersFeedbackSkipLevelSaveKRA")</div>*@
                    </div>
                </div>
            </div>

        </div>
        <div class="row">
            <div class="col-md-12">
                <ul class="nav nav-tabs" id="feedbackTabsSkipLevel">
                    <li class="active">
                        <a href="#tab_a" data-toggle="tab">
                            Overall feedback by skip level manager
                        </a>
                    </li>
                </ul>
                <div class="tab-content">
                    <div class="tab-pane active" id="tab_a">
                        <div class="panel panel-default" id="pnlCompetencyFeedbackGiven">
                            @*<div class="panel-heading">
                                    <h4 class="panel-title">
                                        <a data-toggle="collapse" data-target="#collapseFive" href="#collapseFive" class="collapsed" data-parent="#accordion1">
                                            Overall feedback by skip level manager
                                        </a>
                                    </h4>
                                </div>*@
                            <div id="collapseFive" class="panel-collapse collapse in">
                                <div class="panel-body">
                                    @{Html.RenderPartial("_FeedbackGivenBySkipLevelManager");}
                                </div>
                            </div>
                        </div>
                        <div id="AddManagersFeedbackBC">@Html.Partial("../Feedback/_AddManagerFeebackSkipLevelSave")</div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>
@section scripts{
    <link href="~/Content/toastr.min.css" rel="stylesheet" />
    <script src="~/Scripts/PEPScripts/toastr.min.js"></script>
    <script src="~/Scripts/PEPScripts/CommonConfig.js"></script>
    <script src="~/Scripts/PEPScripts/Common.js"></script>
    <script src="~/Scripts/jquery-ui-1.8.24.min.js"></script>
    <script src="~/Scripts/DataTables/jquery.dataTables.min.js"></script>
    <link href="~/Content/DataTables/css/jquery.dataTables.min.css" rel="stylesheet" />
    <script src="~/Scripts/PEPScripts/FeedbackConsolidatedTraining.js"></script>
    <script src="~/Scripts/PEPScripts/AddManagersFeedback.js"></script>
    <script src="~/Scripts/PEPScripts/Feedback.js"></script>

    @*<script src="~/Scripts/PEPScripts/Ratings.js"></script>*@
    <script type="text/javascript">
        function RemoveScript(id) {
            var txtValue = $('#' + id).val();
            $('#' + id).val(txtValue.replace(/[\<\>=]+/g, ''));
        }
    </script>
}
