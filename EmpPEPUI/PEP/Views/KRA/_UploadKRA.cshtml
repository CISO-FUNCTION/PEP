@using EmpPEP.UI.Views.KRA;
<div class="table-responsive">
    <form id="formKRAEdit">
        <table class="table table-striped tbl-my-kra" id="tblUploadKRAEdit">
            <thead>
                <tr>
                   
                    <th>Project Name</th>
                    <th>Employees</th>
                    <th>G&Os Set</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <tr>
                   
                    <td>
                        <input type="text" placeholder="Type Project Name Here" id="txtProjects" onkeyup="RemoveScript('txtProjects');" class="input-exit form-control" />
                        <input type="hidden" id="hdnProjectId" name="hdnProjectId" />
                    </td>
                    <td>
                        <div id="divEmployeeList">
                            <input type="checkbox" name="Allemployees" value='-1' id="chkAll" ><span id="spnchkAll"><b>All Employees</b></span>  <br>
                            <fieldset class="checkboxgroup" id="ChkLstEmployee"></fieldset>
                        </div>
                    </td>
                   
                    <td>
                        <select id="ddlKRASet" class="input-exit form-control"></select>

                    </td>
                    <td colspan="8" class="text-center">
                        <input type="button" id="btnGetKRAtoUpload" class="btn btn-primary" value="Load G&Os"/>
                    </td>
                </tr>
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="12">
                        <div class="alert alert-success display-hide" style="display: none;" id="divUploadValidationAlert">
                        </div>
                    </td>
                </tr>
            </tfoot>
        </table>
    </form>
</div>