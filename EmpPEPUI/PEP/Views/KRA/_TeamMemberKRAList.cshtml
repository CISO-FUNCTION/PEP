@using EmpPEP.UI.Views.KRA;


<link href="/Content/themes/base/jquery-ui.css" rel="stylesheet" />

<script>

    var ddlAppCycleId = "@ViewBag.AppraisalCycleId";

</script>
<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="alert alert-success display-hide" style="display: none;" id="divValidationAlert_Team">
            </div>
        </div>
    </div>
</div>
<div class="">
    <div class="table-responsive">
        @*<div class="table-responsive" style="height: 200px">*@
        <div style="float: right; margin-bottom: 10px;">
            <div style="float: right;">
                <button type="button" id="btnAddNewGoalTeam" class="btn btn-primary" onclick="OpenAddGoalModalCommon('team')" style="display:none;">
                    <i class="glyphicon glyphicon-plus"></i> Add Goal
                </button>
            </div>
        </div>
        <table class="table table-striped tbl-my-kra" id="tblTeamMemberKRAList" style="display:none;">
            <thead style="text-align: center;">
                <tr>
                    <th style="display: none">KRAId</th>
                    <th style="text-align: center;">@KRA.strSeqNo</th>
                    <th style="text-align: left;">@KRA.strGoalType</th>
                    <th style="text-align: center;">Key Responsibility Area (KRA)</th>
                    <th style="text-align: center;">Key Performance Indicators (KPIs)</th>
                    <th style="text-align: center;">Action Plan</th>
                    <th style="text-align: center;">Weightage (%)</th>
                    <th style="text-align: center;">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
        <!-- Footer information div (replaces tfoot) - matches employee tblKRAListFooter with Status, Start Date, End Date -->
        <div id="tblTeamMemberKRAListFooter" style="background-color: #f5f5f5; border-top: 2px solid #ddd; padding: 12px; display: none; justify-content: space-between; align-items: center; flex-wrap: wrap;">
            <div style="display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
                <div style="display: flex; align-items: center; gap: 5px;">
                    <label style="margin: 0; font-weight: 100 !important;">Status:</label>
                    <label id="lblTeamKRAStatus" class="form-control-static" style="margin: 0; padding: 7px 12px; display: inline-block; min-width: 150px; text-align: left; font-weight: bold;">-</label>
                </div>
                <div style="display: flex; align-items: center; gap: 5px;">
                    <label style="margin: 0; font-weight: 100 !important;">Start Date:</label>
                    <label id="lblTeamStartDate" class="form-control-static" style="margin: 0; padding: 7px 12px; display: inline-block; min-width: 150px; text-align: left; font-weight: bold;">-</label>
                </div>
                <div style="display: flex; align-items: center; gap: 5px;">
                    <label style="margin: 0; font-weight: 100 !important;">End Date:</label>
                    <label id="lblTeamEndDate" class="form-control-static" style="margin: 0; padding: 7px 12px; display: inline-block; min-width: 150px; text-align: left; font-weight: bold;">-</label>
                </div>
            </div>
            <div id="btnApproveTeam" style="display: none; flex-direction: row; align-items: center; gap: 10px;">
                <input type="button" id="btnSubmitKRATeam" class="btn btn-primary" value="@KRA.strKRASubmit" onclick="SubmitKRAFormTeam()" style="display:none;" />
                                <input type="button" id="btnApproveKRA" class="btn btn-danger" value="@KRA.strKRAApprove" onclick="ApproveKRA()" style="display:none" />
                                <input type="button" id="btnRejectKRA" class="btn btn-danger" value="@KRA.strKRAReject" onclick="RejectKRA()" style="display:none" />
            </div>
        </div>
    </div>
</div>

<style type="text/css">
    /* Manager Add Goal modal: scrollable body and training list so Save button stays visible */
    #addGoalModalManager .modal-body {
        max-height: 70vh;
        overflow-y: auto;
    }
    #addGoalModalManager #selectedTrainingListManager {
        max-height: 180px;
        overflow-y: auto;
        overflow-x: auto;
    }
</style>
<!-- Add Goal Modal for Manager - Separate modal with different IDs -->
<div class="modal fade" id="addGoalModalManager" tabindex="-1" role="dialog" aria-labelledby="addGoalModalManagerLabel">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title" id="addGoalModalManagerLabel">Add New Goal</h4>
            </div>
            <div class="modal-body">
                <form id="formKRAEditModalManager">
                    <input type="hidden" id="hdnKRAIdManager" />
                    <input type="hidden" id="lblKRASequenceManager" value="1" />
                    
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="ddlGoalTypeModalManager">@KRA.strGoalType <span class="text-danger">*</span></label>
                                <select id="ddlGoalTypeModalManager" class="form-control">
                                    <option value="">-- Select Goal Type --</option>
                                    <option value="S">Strategic Goal (AI-Themed)</option>
                                    <option value="O">Operational</option>
                                    <option value="D">Developmental</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group">
                                <label for="txtGoalWeightageModalManager">@KRA.strWeightage <span class="text-danger">*</span></label>
                                <input type="text" id="txtGoalWeightageModalManager" class="form-control" maxlength="2" />
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="form-group">
                                <label for="txtGoalDescModalManager">Key Performance Indicators (KPIs) <span class="text-danger">*</span></label>
                                <input type="text" id="txtGoalDescModalManager" class="form-control" maxlength="250" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label for="txtAreaMeasureModalManager">@KRA.strMeasure <span class="text-danger">*</span></label>
                                <textarea id="txtAreaMeasureModalManager" class="form-control" rows="3" maxlength="990"></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4" style="display: none;">
                            <div class="form-group">
                                <label for="txtKRAStartDateModalManager">Cycle Start Date <span class="text-danger">*</span></label>
                                <input type="text" id="txtKRAStartDateModalManager" class="form-control" readonly="readonly" style="background-color: white; cursor: pointer;" />
                            </div>
                        </div>
                        <div class="col-md-4" style="display: none;">
                            <div class="form-group">
                                <label for="txtKRAEndDateModalManager">Cycle End Date <span class="text-danger">*</span></label>
                                <input type="text" id="txtKRAEndDateModalManager" class="form-control" readonly="readonly" style="background-color: #f5f5f5;" />
                            </div>
                        </div>
                    </div>

                    <div class="row" id="trainingRequirementRowManager" style="display: none;">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label for="ddlTrainingRequirementManager">Training Requirement</label>
                                <div style="display: flex; align-items: center; gap: 5px;">
                                    <select id="ddlTrainingRequirementManager" class="form-control" style="display: none; width: 300px !important;">
                                        <option value="">-- Select Training/Certification --</option>
                                    </select>
                                    <input type="text" id="txtTrainingRequirementOtherManager" class="form-control" placeholder="Enter training/certification name" style="display: none; width: 300px;" maxlength="500" />
                                    <button type="button" class="btn btn-primary" id="btnAddTrainingOtherManager" style="display: none;">
                                        <i class="glyphicon glyphicon-plus"></i> Add
                                    </button>
                                    <button type="button" class="btn btn-default" id="btnCancelTrainingOtherManager" style="display: none;">
                                        <i class="glyphicon glyphicon-remove"></i> Cancel
                                    </button>
                                </div>
                                <div id="selectedTrainingListManager" style="margin-top: 10px; display: none; line-height: 2;">
                                    <!-- Multiple training requirements will be added here dynamically -->
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="modalValidationAlertManager" class="alert alert-danger" style="display: none;"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSaveGoalModalManager">Save Goal</button>
            </div>
                        </div>
    </div>
</div>

<script type="text/javascript">
    // Initialize modal event handlers when this partial is loaded
    // This ensures handlers work even if modal is added dynamically
    $(document).ready(function() {
        // Re-initialize handlers using event delegation (works even if modal is added later)
        // These handlers are safe to call multiple times due to .off() before .on()
        
        // Initialize datepicker and load training when Manager Modal is shown
        $(document).off('shown.bs.modal', '#addGoalModalManager');
        $(document).on('shown.bs.modal', '#addGoalModalManager', function() {
            // Initialize datepicker
            setTimeout(function() {
                if (typeof InitializeStartDatePickerManager === 'function') {
                    InitializeStartDatePickerManager();
                }
                
                // Ensure Select2 is initialized for training requirement dropdown
                // This is especially important when opening from dashboard
                if ($('#ddlTrainingRequirementManager').is(':visible') && 
                    $('#ddlTrainingRequirementManager').find('option').length > 1) {
                    // Wait a bit for Select2 to be available (in case it's still loading)
                    setTimeout(function() {
                        if (typeof InitializeTrainingRequirementSelect2Manager === 'function') {
                            InitializeTrainingRequirementSelect2Manager();
                        }
                    }, 200);
                }
            }, 100);
            
            // CRITICAL: Hide training requirement row by default - only show if Goal Type is 'D'
            var goalType = $('#ddlGoalTypeModalManager').val();
            if (goalType && typeof goalType === 'string') {
                goalType = goalType.trim().toUpperCase();
                // Normalize GoalType to handle both 'O'/'D' and 'Operational'/'Developmental'
                if (goalType === 'OPERATIONAL' || goalType.startsWith('OPERATIONAL')) {
                    goalType = 'O';
                } else if (goalType === 'DEVELOPMENTAL' || goalType.startsWith('DEVELOPMENTAL')) {
                    goalType = 'D';
                } else {
                    goalType = goalType.charAt(0).toUpperCase(); // Take first character
                }
            }
            
            // Only show training requirement row if Goal Type is 'D' (Developmental)
            if (goalType === 'D') {
                $('#trainingRequirementRowManager').show();
            } else {
                $('#trainingRequirementRowManager').hide();
            }
            
            // For Developmental goals, ensure training dropdown is loaded so users can add more
            if (goalType === 'D') {
                var $dropdown = $('#ddlTrainingRequirementManager');
                if ($dropdown.find('option').length <= 2) {
                    if (typeof LoadTrainingRequirementsManager === 'function') {
                        LoadTrainingRequirementsManager();
                    }
                } else {
                    setTimeout(function() {
                        if (typeof InitializeTrainingRequirementSelect2Manager === 'function') {
                            InitializeTrainingRequirementSelect2Manager();
                        }
                    }, 300);
                }
            }
        });
        
        // Clear form when Manager Modal is hidden
        $(document).off('hidden.bs.modal', '#addGoalModalManager');
        $(document).on('hidden.bs.modal', '#addGoalModalManager', function() {
            if (typeof ClearKRAFormModalManager === 'function') {
                ClearKRAFormModalManager();
            }
        });
        
        // Save button click handler for Manager Modal
        $(document).off('click', '#btnSaveGoalModalManager');
        $(document).on('click', '#btnSaveGoalModalManager', function() {
            if (typeof SaveKRAFormModalManager === 'function') {
                SaveKRAFormModalManager();
            } else {
                console.error('SaveKRAFormModalManager function not found');
            }
        });
        
        // Goal type change handler for Manager Modal
        $(document).off('change', '#ddlGoalTypeModalManager');
        $(document).on('change', '#ddlGoalTypeModalManager', function() {
            if (typeof OnGoalTypeChangeModalManager === 'function') {
                OnGoalTypeChangeModalManager();
            } else {
                console.error('OnGoalTypeChangeModalManager function not found');
            }
        });
        
        // Training requirement handlers for Manager Modal
        $(document).off('click', '#btnAddTrainingRequirementManager');
        $(document).on('click', '#btnAddTrainingRequirementManager', function() {
            // Check if dropdown is visible (not hidden)
            if ($('#ddlTrainingRequirementManager').is(':visible') && $('#ddlTrainingRequirementManager').css('display') !== 'none') {
                // Check if "Others" (value 0) is selected
                var selectedValue = $('#ddlTrainingRequirementManager').val();
                // Check if "Others" (value 0) is selected
                var selectedValue = $('#ddlTrainingRequirementManager').val();
                if (selectedValue === '0' || selectedValue === 0 || selectedValue === '0') {
                    // Show textbox and Cancel button
                    var $dropdown = $('#ddlTrainingRequirementManager');
                    if ($dropdown.hasClass('select2-hidden-accessible')) {
                        $dropdown.select2('destroy');
                    }
                    $dropdown.hide();
                    $('#txtTrainingRequirementOtherManager').show().focus();
                    $('#btnAddTrainingRequirementManager').html('<i class="glyphicon glyphicon-ok"></i> Save');
                    // Show Cancel button with explicit inline-block display
                    var $cancelBtn = $('#btnCancelTrainingOtherManager');
                    $cancelBtn.css('display', 'inline-block').show();
                    console.log('Cancel button shown from Add button click, display:', $cancelBtn.css('display'));
                } else if (typeof HandleAddTrainingRequirementManager === 'function') {
                    HandleAddTrainingRequirementManager();
                }
            } else if ($('#txtTrainingRequirementOtherManager').is(':visible')) {
                if (typeof HandleSaveTrainingOtherManager === 'function') {
                    HandleSaveTrainingOtherManager();
                }
            } else {
                $('#ddlTrainingRequirementManager').show();
            }
        });
        
        // Handle dropdown change for Manager Modal
        $(document).off('change select2:select', '#ddlTrainingRequirementManager');
        $(document).on('change select2:select', '#ddlTrainingRequirementManager', function(e) {
            var selectedValue = $(this).val();
            var selectedText = $(this).find('option:selected').text();
            console.log('Manager dropdown changed, value:', selectedValue, 'text:', selectedText);
            
            if (selectedValue === '0' || selectedValue === 0 || selectedValue === '0') {
                // All static options (Soft Skill, Compliance, Process, Domain, Other) show textbox
                var $dropdown = $(this);
                // Store the selected option text for reference
                $('#txtTrainingRequirementOtherManager').data('category', selectedText);
                
                if ($dropdown.hasClass('select2-hidden-accessible')) {
                    $dropdown.select2('destroy');
                }
                $dropdown.hide();
                $('#txtTrainingRequirementOtherManager').attr('placeholder', 'Enter ' + selectedText.toLowerCase() + ' name').show().focus();
                $('#btnAddTrainingOtherManager').show();
                // Show Cancel button with explicit inline-block display
                var $cancelBtn = $('#btnCancelTrainingOtherManager');
                $cancelBtn.css('display', 'inline-block').show();
            } else if (selectedValue && selectedValue !== '' && selectedValue !== '0') {
                if (typeof HandleAddTrainingRequirementManager === 'function') {
                    HandleAddTrainingRequirementManager();
                }
            }
        });
        
        // Also handle regular change event as fallback (for non-Select2 scenarios)
        $(document).off('change', '#ddlTrainingRequirementManager:not(.select2-hidden-accessible)');
        $(document).on('change', '#ddlTrainingRequirementManager:not(.select2-hidden-accessible)', function(e) {
            var selectedValue = $(this).val();
            var selectedText = $(this).find('option:selected').text();
            if (selectedValue === '0' || selectedValue === 0 || selectedValue === '0') {
                var $dropdown = $(this);
                // Store the selected option text for reference
                $('#txtTrainingRequirementOtherManager').data('category', selectedText);
                $dropdown.hide();
                $('#txtTrainingRequirementOtherManager').attr('placeholder', 'Enter ' + selectedText.toLowerCase() + ' name').show().focus();
                $('#btnAddTrainingOtherManager').show();
                // Show Cancel button with explicit inline-block display
                var $cancelBtn = $('#btnCancelTrainingOtherManager');
                $cancelBtn.css('display', 'inline-block').show();
            }
        });
        
        // Handle Add button for Others textbox in Manager Modal
        $(document).off('click', '#btnAddTrainingOtherManager');
        $(document).on('click', '#btnAddTrainingOtherManager', function() {
            if (typeof HandleSaveTrainingOtherManager === 'function') {
                HandleSaveTrainingOtherManager();
            }
        });
        
        // Handle Others textbox Enter key for Manager Modal
        $(document).off('keypress', '#txtTrainingRequirementOtherManager');
        $(document).on('keypress', '#txtTrainingRequirementOtherManager', function(e) {
            if (e.which === 13) {
                e.preventDefault();
                if (typeof HandleSaveTrainingOtherManager === 'function') {
                    HandleSaveTrainingOtherManager();
                }
            }
        });
        
        // Handle Cancel button for Others in Manager Modal
        $(document).off('click', '#btnCancelTrainingOtherManager');
        $(document).on('click', '#btnCancelTrainingOtherManager', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            // CRITICAL: Ensure training requirement row is visible FIRST
            $('#trainingRequirementRowManager').css('display', 'block').show();
            
            var $dropdown = $('#ddlTrainingRequirementManager');
            
            // Hide Others textbox and buttons only (NOT the row)
            $('#txtTrainingRequirementOtherManager').hide().val('').removeData('category').attr('placeholder', 'Enter training/certification name');
            $('#btnAddTrainingOtherManager').hide();
            $('#btnCancelTrainingOtherManager').hide();
            
            // Show dropdown BEFORE initializing Select2
            $dropdown.css('display', 'block').show();
            $('#btnAddTrainingRequirementManager').html('<i class="glyphicon glyphicon-plus"></i> Add');
            
            // Re-initialize Select2 and show dropdown
            if (!$dropdown.hasClass('select2-hidden-accessible')) {
                // Use setTimeout to ensure dropdown is visible before initializing
                setTimeout(function() {
                    if ($dropdown.is(':visible')) {
                        InitializeTrainingRequirementSelect2Manager();
                    }
                }, 100);
            } else {
                // If Select2 is already initialized, just show it
                $dropdown.show();
                // Show Select2 container if it exists
                $dropdown.next('.select2-container').show();
            }
            
            // Reset dropdown value
            if ($dropdown.hasClass('select2-hidden-accessible')) {
                $dropdown.val(null).trigger('change');
            } else {
                $dropdown.val('');
            }
            
            // Double-check row is still visible after all operations
            setTimeout(function() {
                $('#trainingRequirementRowManager').css('display', 'block').show();
            }, 200);
        });
        
        // Handle Remove Training button for Manager Modal (legacy - now using RemoveTrainingRequirementFromListManager)
        $(document).off('click', '#btnRemoveTrainingManager');
        $(document).on('click', '#btnRemoveTrainingManager', function() {
            if (typeof HandleRemoveTrainingManager === 'function') {
                HandleRemoveTrainingManager();
            }
        });
    });
</script>
