@* Goal Modification Request Approval List for Managers *@


<div class="row" style="margin-top: 20px;">
    <div class="col-md-12">
        <div class="table-responsive">
            <!-- Bulk action toolbar -->
            <div class="row" style="margin-bottom: 10px;">
                <div class="col-md-12 text-right">
                    <button type="button" id="btnBulkApprove" class="btn btn-success btn-sm" style="display:none; margin-right: 5px;">
                        <i class="fa fa-check"></i> Approve Selected
                    </button>
                    <button type="button" id="btnBulkReject" class="btn btn-danger btn-sm" style="display:none;">
                        <i class="fa fa-times"></i> Reject Selected
                    </button>
                </div>
            </div>

            <table id="tblGoalModificationRequests" class="table table-bordered table-hover">
                <thead class="thead-light">
                    <tr>
                        <th style="width:40px; text-align:center;">
                            <input type="checkbox" id="chkSelectAllRequests" />
                        </th>
                        <th>Employee Name</th>
                        <th>Reason</th>
                        <th>Request Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="tbodyGoalModificationRequests">
                    <tr>
                        <td colspan="6" class="text-center">
                            <i class="fa fa-spinner fa-spin"></i> Loading requests...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Approval Modal -->
<div class="modal fade" id="approvalModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">Approve Goal Modification Request</h4>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to approve this goal modification request?</p>
                <div class="alert alert-info">
                    <strong>Note:</strong> Once approved, the employee will be able to edit their goals. The edited goals will need to be re-submitted and approved following the standard workflow.
                </div>
                <input type="hidden" id="hdnApproveRequestId" />
            </div>
            <div class="modal-footer">
                @*<button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>*@
                <button type="button" class="btn btn-success" id="btnConfirmApprove">
                    <i class="fa fa-check"></i> Approve
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Rejection Modal -->
<div class="modal fade" id="rejectionModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">Reject Goal Modification Request</h4>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label for="txtRejectionReason">Reason for Rejection <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="txtRejectionReason" rows="4" 
                              placeholder="Please provide a reason for rejecting this request..." 
                              maxlength="500"></textarea>
                    <small class="text-muted">Maximum 500 characters</small>
                </div>
                <div class="alert alert-danger" id="rejectionErrorMsg" style="display:none;"></div>
                <input type="hidden" id="hdnRejectRequestId" />
            </div>
            <div class="modal-footer">
                @*<button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>*@
                <button type="button" class="btn btn-danger" id="btnConfirmReject">
                    <i class="fa fa-times"></i> Reject
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    #tblGoalModificationRequests th {
        background-color: #f8f9fa;
        font-weight: 600;
        text-align: center;
        vertical-align: middle;
    }
    
    #tblGoalModificationRequests td {
        vertical-align: middle;
    }
    
    .badge-request {
        font-size: 12px;
        padding: 4px 8px;
    }
    
    /* Blinking animation for pending request badge */
    .badge-blink {
        animation: blink 1.5s infinite;
    }
    
    @@keyframes blink {
        0%, 100% {
            opacity: 1;
            transform: scale(1);
        }
        50% {
            opacity: 0.5;
            transform: scale(1.1);
        }
    }
    
    .status-pending {
        color: #856404;
        background-color: #fff3cd;
        border: 1px solid #ffeeba;
        padding: 4px 12px;
        border-radius: 4px;
        font-weight: 500;
    }
    
    .status-approved {
        color: #155724;
        background-color: #d4edda;
        border: 1px solid #c3e6cb;
        padding: 4px 12px;
        border-radius: 4px;
        font-weight: 500;
    }
    
    .status-rejected {
        color: #721c24;
        background-color: #f8d7da;
        border: 1px solid #f5c6cb;
        padding: 4px 12px;
        border-radius: 4px;
        font-weight: 500;
    }
</style>
