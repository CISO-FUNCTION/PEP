                // Capture which block elements (p, li) are selected before button click loses selection
                _listMouseDownHandler = function (e) {
                    var btn = e.target && e.target.closest && e.target.closest('.note-toolbar button');
                    if (!btn) return;
                    var icon = btn.querySelector('i');
                    if (!icon) return;
                    var iconClass = icon.className || '';
                    if (iconClass.indexOf('glyphicon-list') === -1 && iconClass.indexOf('fa-list-ol') === -1) return;
                    
                    // Find which editor this button belongs to
                    var $editorEl = $(btn).closest('.note-editor').prev();
                    if (!$editorEl.data('summernote')) return;
                    
                    var editable = $(btn).closest('.note-editor').find('.note-editable')[0];
                    if (!editable) return;
                    
                    // Get current selection
                    var sel = window.getSelection();
                    if (!sel || sel.rangeCount === 0) {
                        _savedRange = null;
                        return;
                    }
                    
                    var range = sel.getRangeAt(0);
                    
                    // Find all block elements (P and LI) in the editable area
                    var allBlocks = editable.querySelectorAll('p, li');
                    var selectedIndices = [];
                    
                    // Check which block elements intersect with the selection
                    for (var i = 0; i < allBlocks.length; i++) {
                        var blockNode = allBlocks[i];
                        var blockRange = document.createRange();
                        blockRange.selectNode(blockNode);
                        
                        // Check if this block intersects with selection
                        var selectionIntersects = 
                            range.compareBoundaryPoints(Range.START_TO_END, blockRange) >= 0 &&
                            range.compareBoundaryPoints(Range.END_TO_START, blockRange) <= 0;
                        
                        if (selectionIntersects) {
                            selectedIndices.push(i);
                        }
                    }
                    
                    // Save the indices of selected blocks
                    _savedRange = selectedIndices.length > 0 ? selectedIndices : null;
                };
                
                _listClickHandler = function (e) {
                    var btn = e.target && e.target.closest && e.target.closest('.note-toolbar button');
                    if (!btn) return;
                    var icon = btn.querySelector('i');
                    if (!icon) return;
                    var iconClass = icon.className || '';
                    var isUL = iconClass.indexOf('glyphicon-list') !== -1;
                    var isOL = iconClass.indexOf('fa-list-ol') !== -1;
                    if (!isUL && !isOL) return;
                    
                    // Find which editor this button belongs to
                    var $editorEl = $(btn).closest('.note-editor').prev();
                    if (!$editorEl.data('summernote')) return;
                    
                    // Get current HTML content
                    var html = $editorEl.summernote('code');
                    
                    var listTag = isUL ? 'ul' : 'ol';
                    var newHtml = '';
                    
                    // Parse HTML to extract all block-level elements (P, LI)
                    var tempDiv = document.createElement('div');
                    tempDiv.innerHTML = html;
                    
                    // Get all P and LI elements
                    var allBlocks = tempDiv.querySelectorAll('p, li');
                    
                    // Safety check
                    if (!allBlocks || allBlocks.length === 0) {
                        _savedRange = null;
                        return;
                    }
                    
                    // If we have saved selected block indices (user selected specific lines)
                    if (_savedRange && Array.isArray(_savedRange) && _savedRange.length > 0) {
                        var result = [];
                        var inList = false;
                        var currentListType = null;
                        
                        for (var i = 0; i < allBlocks.length; i++) {
                            var block = allBlocks[i];
                            var isSelected = _savedRange.indexOf(i) !== -1;
                            var content = block.innerHTML;
                            
                            if (isSelected) {
                                // Convert to list item
                                if (!inList) {
                                    result.push('<' + listTag + '>');
                                    inList = true;
                                    currentListType = listTag;
                                }
                                result.push('<li>' + content + '</li>');
                            } else {
                                // Keep as is (paragraph or existing list item in different list)
                                if (inList) {
                                    result.push('</' + currentListType + '>');
                                    inList = false;
                                    currentListType = null;
                                }
                                
                                // If it's already a list item, wrap in its parent list type
                                if (block.tagName.toLowerCase() === 'li') {
                                    var parentList = block.parentElement;
                                    var parentListType = parentList ? parentList.tagName.toLowerCase() : 'ul';
                                    
                                    // Check if previous item was also from same parent
                                    var prevBlock = i > 0 ? allBlocks[i - 1] : null;
                                    var sameParent = prevBlock && prevBlock.tagName.toLowerCase() === 'li' && 
                                                     prevBlock.parentElement === parentList;
                                    
                                    if (!sameParent) {
                                        result.push('<' + parentListType + '>');
                                    }
                                    result.push('<li>' + content + '</li>');
                                    
                                    // Check if next item is from different parent
                                    var nextBlock = i < allBlocks.length - 1 ? allBlocks[i + 1] : null;
                                    var nextSameParent = nextBlock && nextBlock.tagName.toLowerCase() === 'li' && 
                                                         nextBlock.parentElement === parentList;
                                    
                                    if (!nextSameParent) {
                                        result.push('</' + parentListType + '>');
                                    }
                                } else {
                                    // It's a paragraph
                                    result.push('<p>' + content + '</p>');
                                }
                            }
                        }
                        
                        if (inList) {
                            result.push('</' + currentListType + '>');
                        }
                        
                        newHtml = result.join('');
                    } else {
                        // No selection - convert all to list
                        var items = [];
                        for (var i = 0; i < allBlocks.length; i++) {
                            items.push('<li>' + allBlocks[i].innerHTML + '</li>');
                        }
                        newHtml = '<' + listTag + '>' + items.join('') + '</' + listTag +'>';
                    }
                    
                    // Safety check: don't set empty content
                    if (!newHtml || newHtml.trim() === '') {
                        _savedRange = null;
                        return;
                    }
                    
                    // Set the new HTML
                    $editorEl.summernote('code', newHtml);
                    
                    // Clear saved range
                    _savedRange = null;
                    
                    // Prevent Summernote's default handler
                    e.stopImmediatePropagation();
                    e.preventDefault();
                };
                
                document.getElementById('addGoalModal').addEventListener('mousedown', _listMouseDownHandler, true);
                document.getElementById('addGoalModal').addEventListener('click', _listClickHandler, true);
            });
            
            // Clear form and destroy Summernote editors when modal is hidden
            $('#addGoalModal').on('hidden.bs.modal', function() {
                // Remove custom UL/OL capture handlers
                if (_listMouseDownHandler) {
                    document.getElementById('addGoalModal').removeEventListener('mousedown', _listMouseDownHandler, true);
                    _listMouseDownHandler = null;
                }
                if (_listClickHandler) {
                    document.getElementById('addGoalModal').removeEventListener('click', _listClickHandler, true);
                    _listClickHandler = null;
                }
                _savedRange = null;
                // Destroy Summernote editors
                if ($('#txtGoalDescModal').data('summernote')) {
                    $('#txtGoalDescModal').summernote('destroy');
                }
                if ($('#txtAreaMeasureModal').data('summernote')) {
                    $('#txtAreaMeasureModal').summernote('destroy');
                }
                if ($('#txtActionPlanModal').data('summernote')) {
                    $('#txtActionPlanModal').summernote('destroy');
                }
                
                // CRITICAL FIX: Close Select2 dropdown
                var $dropdown = $('#ddlTrainingRequirement');
                
                // Close and destroy Select2 to reset state
                if ($dropdown.hasClass('select2-hidden-accessible')) {
                    try {
                        $dropdown.select2('close');
                        $dropdown.select2('destroy');
                    } catch (e) {
                        // Ignore errors
                    }
                }
                
                ClearKRAFormModal();
                
                // CRITICAL: Explicitly clear all stored modal data after closing
                $('#addGoalModal').removeData('goalDescription');
                $('#addGoalModal').removeData('measure');
                $('#addGoalModal').removeData('actionPlan');
                $('#addGoalModal').removeData('isEditMode');
                $('#addGoalModal').removeData('teamMemberId');
                $('#addGoalModal').removeData('isTeamMode');
                
                // Restore KRA list visibility (in case save failed or user cancelled after validation error)
                if ($('#tblKRAList').length) {
                    if ($('#tblKRAList_wrapper').length) $('#tblKRAList_wrapper').show();
                    $('#tblKRAList').show();
                    if ($('#tblKRAListFooter').length) $('#tblKRAListFooter').show();
                    if ($('#KRAListGird').length) $('#KRAListGird').show();
                }
                // Ensure training requirement section is hidden
                $('#trainingRequirementRow').hide();
                ClearTrainingRequirement();
            });
            
            // Save button click handler (using event delegation to ensure it works)
            $(document).off('click', '#btnSaveGoalModal');
            $(document).on('click', '#btnSaveGoalModal', function() {
                SaveKRAFormModal();
            });
            
            // Goal type change handler
            $(document).off('change', '#ddlGoalTypeModal');
            $(document).on('change', '#ddlGoalTypeModal', function() {
                OnGoalTypeChangeModal();
            });
            
            // Load training requirements when modal is shown (only if no training data exists)
            $('#addGoalModal').on('shown.bs.modal', function() {
                // CRITICAL: Hide training requirement row by default - only show if Goal Type is 'D'
                var goalType = $('#ddlGoalTypeModal').val();
                if (goalType && typeof goalType === 'string') {
                    goalType = goalType.trim().toUpperCase();
                    // Normalize GoalType to handle both 'O'/'D' and 'Operational'/'Developmental'
                    if (goalType === 'OPERATIONAL' || goalType.startsWith('OPERATIONAL')) {
                        goalType = 'O';
                    } else if (goalType === 'DEVELOPMENTAL' || goalType.startsWith('DEVELOPMENTAL')) {
                        goalType = 'D';
                    } else if (goalType === 'STRATEGIC GOAL (AI-THEMED)' || goalType.startsWith('STRATEGIC')) {
                        goalType = 'S';
                    } else {
                        goalType = goalType.charAt(0).toUpperCase(); // Take first character
                    }
                }
                
                // Only show training requirement row if Goal Type is 'D' (Developmental)
                if (goalType === 'D') {
                    $('#trainingRequirementRow').show();
                } else {
                    $('#trainingRequirementRow').hide();
                    if (typeof ClearTrainingRequirement === 'function') {
                        ClearTrainingRequirement();
                    }
                }
                
                // For Developmental goals, ensure training dropdown is loaded so users can add more
                if (goalType === 'D') {
                    var trainingData = (typeof GetTrainingDataArray === 'function') ? GetTrainingDataArray() : [];
                    if (trainingData.length === 0) {
                        LoadTrainingRequirements();
                    } else {
                        // Training already populated by OpenEditGoalModalCommon — ensure dropdown stays visible
                        if ($('#ddlTrainingRequirement option').length <= 6) {
                            LoadTrainingRequirements();
                        } else if (typeof InitializeTrainingRequirementSelect2 === 'function') {
                            InitializeTrainingRequirementSelect2();
                        }
                    }
                }
                // Note: If training exists, the dropdown is already shown by OpenEditGoalModalCommon
                // Do not hide the dropdown here - user should be able to add more trainings during edit
            });
            
            // Training requirement handlers
            $(document).off('click', '#btnAddTrainingRequirement');
            $(document).on('click', '#btnAddTrainingRequirement', function() {
                var btnText = $(this).text().trim();
                // Check if dropdown is visible
                if ($('#ddlTrainingRequirement').is(':visible')) {
                    // Dropdown is visible, handle selection
                    HandleAddTrainingRequirement();
                } else if ($('#txtTrainingRequirementOther').is(':visible')) {
                    // Others textbox is visible, save it
                    HandleSaveTrainingOther();
                } else {
                    // Neither is visible, show dropdown
                    $('#ddlTrainingRequirement').show();
                }
            });
            
            // Handle dropdown change - auto-add when selection is made
            // Select2 triggers 'select2:select' event, but we also handle regular 'change' for compatibility
            $(document).off('change select2:select', '#ddlTrainingRequirement');
            $(document).on('change select2:select', '#ddlTrainingRequirement', function() {
                if (typeof HandleTrainingRequirementDropdownChange === 'function') {
                    HandleTrainingRequirementDropdownChange();
                }
            });
            
            // Handle Others textbox Enter key
            $(document).off('keypress', '#txtTrainingRequirementOther');
            $(document).on('keypress', '#txtTrainingRequirementOther', function(e) {
                if (e.which === 13) { // Enter key
                    e.preventDefault();
                    if (typeof HandleSaveTrainingOther === 'function') {
                        HandleSaveTrainingOther();
                    }
                }
            });
            
            // Note: Removed blur handler - user should explicitly click Add button to save
            
            // Handle Remove Training button
            $(document).off('click', '#btnRemoveTraining');
            $(document).on('click', '#btnRemoveTraining', function() {
                HandleRemoveTraining();
            });
            
            // Handle Add button for Others textbox
            $(document).off('click', '#btnAddTrainingOther');
            $(document).on('click', '#btnAddTrainingOther', function() {
                if (typeof HandleSaveTrainingOther === 'function') {
                    HandleSaveTrainingOther();
                }
            });
            
            // Handle Cancel button for Others
            $(document).off('click', '#btnCancelTrainingOther');
            $(document).on('click', '#btnCancelTrainingOther', function(e) {
                e.preventDefault();
                
                var $dropdown = $('#ddlTrainingRequirement');
                
                // Hide Others textbox and buttons
                $('#txtTrainingRequirementOther').hide().val('');
                $('#btnAddTrainingOther').hide();
                $('#btnCancelTrainingOther').hide();
                
                // Show dropdown (Select2 stays intact - never destroyed)
                $dropdown.show();
                
                // Show Select2 container if hidden
                var $select2Container = $dropdown.next('.select2');
                if ($select2Container.length > 0) {
                    $select2Container.show();
                }
                
                // CRITICAL: Restore modal scroll immediately (same as .Net Developer flow)
                var $modalBody = $dropdown.closest('.modal-body');
                if ($modalBody.length > 0) {
                    $modalBody.css({
                        'overflow-y': 'auto',
                        'pointer-events': 'auto'
                    });
                }
                
                // Reset dropdown value
                if ($dropdown.hasClass('select2-hidden-accessible')) {
                    $dropdown.val(null).trigger('change');
                } else {
                    $dropdown.val('');
                }
            });
        });
    </script>
    <script src="~/Scripts/PEPScripts/GoalModificationManager.js"></script>
}
