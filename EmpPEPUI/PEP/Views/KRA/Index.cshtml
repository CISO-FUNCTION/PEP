@using EmpPEP.UI.Views.KRA;
@{
    ViewBag.Title = "Performance Management System";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<script>
    var strKRAUpdateMsg = "@KRA.strKRAUpdateSuccessMsg";
    var strKRADeleteMsg = "@KRA.strKRADeleteSuccessMsg";
    var strKRAInsertMsg = "@KRA.strKRAInsertSuccessMsg";
    var strKRAInsert = "@KRA.strKRAInsert";
    var strKRAUpdate = "@KRA.strKRAUpdate";
    var strKRAEdit = "@KRA.strKRAEdit";
    var strKRADelete = "@KRA.strKRADelete";
    var strKRAEmptyFieldValidation = "@KRA.strKRAEmptyFieldValidation";
    var strKRANumberRangeValidation = "@KRA.strKRANumberRangeValidation";
    var strKRATextAreaLengthValidation = "@KRA.strKRATextAreaLengthValidation";
    var strKRAErrorMsg = "@KRA.strKRAErrorMsg";
    var strGoalType = "@KRA.strGoalType";
    var strSeqNo = "@KRA.strSeqNo";
    var strGoalDesc = "@KRA.strGoalDesc";
    var strWeightage = "@KRA.strWeightage";
    var strActionStep = "@KRA.strActionStep";
    var strMeasure = "@KRA.strMeasure";
    var strTargetDate = "@KRA.strTargetDate";
    var strKRAStartDate = "@KRA.strKRAStartDate";
    var strKRAEndDate = "@KRA.strKRAEndDate";
    var strKRAStatus = "@KRA.strKRAStatus";
    var strKRAStatusInitialised = "@KRA.strKRAStatusInitialised";
    var strKRAStatusRejected = "@KRA.strKRAStatusRejected";
    var strKRAStatusSubmitted = "@KRA.strKRAStatusSubmitted";
    var strKRAStatusApproved = "@KRA.strKRAStatusApproved";
    var strKRAStatusCompleted = "@KRA.strKRAStatusCompleted";
    var strKRANotSubmitted = "@KRA.strKRANotSubmitted";
    var strKRANotFilled = "@KRA.strKRANotFilled";
    var strPrevKRAValidation = "@KRA.strPrevKRAValidation";
    var strKRADateValidation = "@KRA.strKRADateValidation";
</script>
<style type="text/css">
    #main-wrapper #main .col-md-5.AnnualRating div#lblratingField {
        margin-bottom: 0px !important;
        width: 45%;
    }

    .col-md-5.AnnualRating {
        display: flex;
        align-items: center;
    }

    div#lblratingValue {
        height: 35px;
        position: relative;
        top: -1px;
    }

    .col-md-5.AnnualRating div#lblratingField h4 {
        margin-top: 9px;
        margin-bottom: 9px;
    }
    
    /* Custom Reference Goal Modal - Skills multi-select: allow selected tags to wrap to multiple rows */
    #customReferenceGoalModal .select2-container--default .select2-selection--multiple {
        height: auto !important;
        min-height: 34px !important;
    }

    #customReferenceGoalModal .select2-container--default .select2-selection--multiple .select2-selection__rendered {
        display: flex !important;
        flex-wrap: wrap !important;
        white-space: normal !important;
        padding: 2px 5px !important;
        align-items: flex-start !important;
    }

    #customReferenceGoalModal .select2-container--default .select2-selection--multiple .select2-selection__choice {
        float: none !important;
        display: inline-flex !important;
        align-items: center !important;
        margin: 2px 4px 2px 0 !important;
        white-space: nowrap !important;
    }

    #customReferenceGoalModal .select2-container--default .select2-selection--multiple .select2-search--inline {
        float: none !important;
        flex: 1 1 auto !important;
        min-width: 80px !important;
    }

    /* Grade dropdown styling with scroll */
    #ddlReferenceGoalGrade {
        max-height: 250px !important;
    }
    
    /* Custom styling for grade dropdown options with scrollbar */
    select#ddlReferenceGoalGrade {
        overflow-y: auto !important;
        height: auto !important;
    }
    
    /* Select2 dropdown styling for modal */
    .select2-container--open {
        z-index: 99999 !important;
    }

    .select2-dropdown {
        z-index: 99999 !important;
    }

    #addGoalModal .select2-container {
        z-index: 9999 !important;
        width: 100% !important;
    }
    
    /* Ensure Select2 dropdown doesn't cause scroll lock */
    #ddlTrainingRequirement.select2-hidden-accessible ~ .select2-container {
        position: relative !important;
    }
    
    /* Training container - allow natural scrolling when table appears */
    #selectedTrainingListContainer {
        margin-bottom: 20px;
        overflow: visible !important;
    }
    
    /* Ensure modal body has proper padding at bottom */
    #addGoalModal .modal-body {
        padding-bottom: 30px !important;
        max-height: calc(100vh - 180px);
        overflow-y: auto;
        position: relative;
        pointer-events: auto !important;
    }
    
    /* Hide textbox and show label for approver */
    #KRAToSubmitManager {
        display: none !important;
    }
    
    #lblKRAToSubmitManager {
        display: inline-block;
    }
    
    /* Summernote Editor Custom Styling - Override global .btn class */
    .note-editor .note-toolbar {
        background-color: #f5f5f5 !important;
        border-bottom: 1px solid #ddd !important;
    }
    
    /* Override global .btn styling specifically for Summernote editor buttons */
    .note-editor .note-btn-group .note-btn {
        background-color: #e3f2fd !important; /* Light blue background */
        background-image: none !important; /* Remove any inherited gradient */
        border: 1px solid #90caf9 !important; /* Light blue border */
        border-radius: 3px !important; /* Square corners instead of rounded */
        padding: 5px 10px !important;
        color: #1976d2 !important; /* Blue text color */
        transition: all 0.2s ease !important;
        box-shadow: none !important;
    }
    
    .note-editor .note-btn-group .note-btn:hover {
        background-color: #bbdefb !important; /* Slightly darker light blue on hover */
        background-image: none !important;
        border-color: #64b5f6 !important;
        transform: none !important; /* Remove any transform effect */
        box-shadow: none !important;
    }
    
    .note-editor .note-btn-group .note-btn.active,
    .note-editor .note-btn-group .note-btn:active,
    .note-editor .note-btn-group .note-btn:focus {
        background-color: #2196f3 !important;
        background-image: linear-gradient(45deg, #2196f3, #00bcd4) !important;
        border-color: #2196f3 !important;
        color: #fff !important;
        transform: none !important;
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.15) !important;
    }
    
    /* Ensure glyphicons are visible in editor buttons */
    .note-editor .note-btn-group .note-btn .glyphicon,
    .note-editor .note-btn-group .note-btn i {
        display: inline-block !important;
        font-size: 14px !important;
        line-height: 1 !important;
        color: inherit !important;
    }
    
    /* Active state for buttons with icons */
    .note-editor .note-btn-group .note-btn.active .glyphicon,
    .note-editor .note-btn-group .note-btn.active i {
        color: #fff !important;
    }
    
    /* Ensure dropdown toggles in editor also get same styling */
    .note-editor .note-btn-group .dropdown-toggle {
        background-image: none !important;
        border-radius: 3px !important;
    }
    
    .note-editor .note-btn-group .dropdown-toggle:hover,
    .note-editor .note-btn-group .dropdown-toggle:active {
        background-image: linear-gradient(45deg, #2196f314, #00bcd46e) !important;
    }
    
    /* Editable area styling */
    .note-editor.note-frame .note-editing-area .note-editable {
        background-color: #fff !important;
        color: #333 !important;
        min-height: 150px !important;
    }
    
    .note-editor.note-frame .note-editing-area .note-editable:focus {
        background-color: #fff !important;
        outline: none !important;
    }
    
    /* Truncated content styling - hide overflow and limit height */
    .truncated-content {
        display: -webkit-box !important;
        -webkit-line-clamp: 4 !important;
        -webkit-box-orient: vertical !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        word-wrap: break-word !important;
        line-height: 1.6em !important;
        max-height: 6.4em !important;
    /* Add Goal modal: scrollable body so Save/Cancel stay visible when content exceeds */
    #addGoalModal .modal-body {
        max-height: 70vh;
        overflow-y: auto;
    }
    #addGoalModal #selectedTrainingListContainer {
        max-height: 180px;
        overflow-y: auto;
        overflow-x: auto;
    }
    /* Manager Add Goal modal */
    #addGoalModalManager .modal-body {
        max-height: 70vh;
        overflow-y: auto;
    }
    #addGoalModalManager #selectedTrainingListManager {
        max-height: 180px;
        overflow-y: auto;
        overflow-x: auto;
    }
    @@keyframes mf-spin {
        to { transform: rotate(360deg); }
    }
</style>


<div id="main-wrapper">
    <div id="main">
        <div class="row pg-main-title">
            <div class="col-12 pg-title-border" id="kraTitle"><h4><b>Goals & Objectives</b></h4></div>
        </div>
        <div class="row form-group">
            <div class="col-md-4">
                <label for="AppCycle" style="font-weight: bold; margin-bottom: 5px; display: block;">Select Appraisal Cycle:</label>
                <select id="AppCycle" class="form-control" onchange="OnAppraisalCycleChange()"></select>
            </div>
            <div class="col-md-4" id="AssesmentCycledropdown" style="display:none;">
                <label for="ddlSelfAssCycle" style="font-weight: bold; margin-bottom: 5px; display: block;">Select Assessment Cycle:</label>
                <select id="ddlSelfAssCycle" class="form-control" onchange="OnSelfAssesmentCycleChange()"></select>
            </div>
            <div class="col-md-4 AnnualRating">
                <div id="lblratingField" class="pg-title-border"><b>Annual Rating :</b></div>
                <div id="lblratingValue" class="form-control"></div>
            </div>
        </div>
        <div class="row">
            @*<div class="col-md-12 pdtop15" id="myKratabs">*@
            <div class="col-md-12 pdtop15" id="mytabs">
                <ul class="nav nav-tabs" id="kraTabs">
                    <li id="KRATab_A" class="active"><a href="#tab_a" data-toggle="tab">My Goals & Objectives</a></li>
                    <li id="KRATab_B"><a href="#tab_b" data-toggle="tab">Team Goals & Objectives</a></li>
                    <li id="KRATab_C"><a href="#tab_c" data-toggle="tab">All Employee Goals & Objectives</a></li>
                    <li id="KRATab_D"><a href="#tab_d" data-toggle="tab">Upload Goals & Objectives</a></li>
                    <li id="KRATab_E"><a href="#tab_e" data-toggle="tab">Upload Goals & Objectives GradeWise</a></li>
                    @*<li id="KRATab_F" style="display:none;"><a href="#tab_f" data-toggle="tab">Goal Modification Requests <span id="badgeModificationCount" class="badge badge-danger" style="display:none;">0</span></a></li>*@
                </ul>
               
                <div class="tab-content form-group">
                    <div class="tab-pane active" id="tab_a">
                        @Html.Partial("_KRAList")
                        @Html.Partial("_GoalModificationModal")

                        <input type="hidden" id="hdnRoleId" />
                        <input type="hidden" id="hdnDUId" />
                    </div>
                    <div class="tab-pane" id="tab_b">
                        @Html.Partial("_TeamList")
                        @Html.Partial("_TeamMemberKRAList")

                    </div>
                    <div class="tab-pane" id="tab_c">
                        @Html.Partial("_SearchEmployee")
                        @Html.Partial("_TeamMemberKRAList")
                    </div>
                    <div class="tab-pane" id="tab_d">
                        @Html.Partial("_UploadKRA")
                        @Html.Partial("_KRAListToUpload")
                        <input type="button" id="btnApproveUploadKRA" class="btn btn-primary" value="Upload G&Os" />
                    </div>
                    <div class="tab-pane" id="tab_e">
                        @Html.Partial("_UploadKRAGradeWise")
                        @Html.Partial("_KRAListToUploadGW")
                        <input type="button" id="btnApproveUploadKRAGW" class="btn btn-primary" value="Upload G&Os" />
                    </div>
                    <div class="tab-pane" id="tab_f">
                        @Html.Partial("_GoalModificationApprovalList")
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="hdnSelectedSelfAssesmentTab" />

<!-- Common Modal for Add/Edit Goal - Used by all tabs -->
<div class="modal fade" id="addGoalModal" tabindex="-1" role="dialog" aria-labelledby="addGoalModalLabel">
    <div class="modal-dialog modal-lg" role="document" style="width: 90%; max-width: 1100px; margin: 30px auto;">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title" id="addGoalModalLabel">Add New Goal</h4>
            </div>
            <div class="modal-body" style="padding: 20px;">
                <form id="formKRAEditModal">
                    <input type="hidden" id="hdnKRAId" />
                    <input type="hidden" id="lblKRASequence" value="1" />
                    
                    <!-- Row 1: Goal Type and Weightage -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="ddlGoalTypeModal">Goal Type <span class="text-danger">*</span></label>
                                <select id="ddlGoalTypeModal" class="form-control">
                                    <option value="">-- Select Goal Type --</option>
                                    <option value="S">Strategic Goal (AI-Themed)</option>
                                    <option value="O">Operational</option>
                                    <option value="D">Developmental</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="txtGoalWeightageModal">Weightage (%) <span class="text-danger">*</span> <small class="text-muted" style="font-weight: normal;">(Min = 10)</small></label>
                                <input type="text" id="txtGoalWeightageModal" class="form-control" maxlength="2" placeholder="Enter weightage %" />
                                <span id="weightageError" class="text-danger" style="display: none; font-size: 12px; margin-top: 5px;"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Row 2: Key Responsibility Area (KRA) -->
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label for="txtGoalDescModal">
                                    Key Responsibility Area (KRA)
                                    <span class="text-danger">*</span>
                                </label>
                                <div id="txtGoalDescModal" style="min-height: 150px;"></div>
                                <small id="hintGoalDescLength" class="text-muted" style="display:block; margin-top:-12px;">Maximum 2000 characters</small>
                            </div>
                        </div>
                    </div>

                    <!-- Row 3: Key Performance Indicators (KPIs) -->
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label for="txtAreaMeasureModal">
                                    Key Performance Indicators (KPIs)
                                    <span class="text-danger">*</span>
                                </label>
                                <div id="txtAreaMeasureModal" style="min-height: 200px;"></div>
                                <small id="hintMeasureLength" class="text-muted" style="display:block; margin-top:-12px;">Maximum 2000 characters</small>
                            </div>
                        </div>
                    </div>

                    <!-- Row 4: Action Plan -->
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label for="txtActionPlanModal">
                                    Action Plan
                                    <span class="text-danger">*</span>
                                </label>
                                <div id="txtActionPlanModal" style="min-height: 150px;"></div>
                                <small id="hintActionPlanLength" class="text-muted" style="display:block; margin-top:-12px;">Maximum 2000 characters</small>
                            </div>
                        </div>
                    </div>

                    <!-- Hidden Date Fields -->
                    <div class="row" style="display: none;">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="txtKRAStartDateModal">Cycle Start Date <span class="text-danger">*</span></label>
                                <input type="text" id="txtKRAStartDateModal" class="form-control" readonly="readonly" style="background-color: white; cursor: pointer;" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="txtKRAEndDateModal">Cycle End Date <span class="text-danger">*</span></label>
                                <input type="text" id="txtKRAEndDateModal" class="form-control" readonly="readonly" style="background-color: #f5f5f5;" />
                            </div>
                        </div>
                    </div>

                    <!-- Training Requirement (for Developmental Goals) -->
                    <div class="row" id="trainingRequirementRow" style="display: none; margin-bottom: 20px;">
                        <div class="col-md-12">
                            <div class="form-group" style="margin-bottom: 20px;">
                                <label for="ddlTrainingRequirement">Training Requirement</label>
                                
                                <!-- Dropdown for selecting training -->
                                <select id="ddlTrainingRequirement" class="form-control" style="display: none;">
                                    <option value="">-- Select Training/Certification --</option>
                                </select>
                                
                                <!-- Textbox for "Others" option -->
                                <input type="text" id="txtTrainingRequirementOther" class="form-control" placeholder="Enter training/certification name" style="display: none;" maxlength="500" />
                                
                                <!-- Action buttons for Others -->
                                <div style="margin-top: 10px; margin-bottom: 10px;">
                                    <button type="button" class="btn btn-primary btn-sm" id="btnAddTrainingOther" style="display: none;">
                                        <i class="glyphicon glyphicon-plus"></i> Add
                                    </button>
                                    <button type="button" class="btn btn-default btn-sm" id="btnCancelTrainingOther" style="display: none; margin-left: 5px;">
                                        <i class="glyphicon glyphicon-remove"></i> Cancel
                                    </button>
                                </div>
                                
                                <!-- Selected Training List Table -->
                                <div id="selectedTrainingListContainer" style="margin-top: 10px; margin-bottom: 15px; display: none;">
                                    <table id="selectedTrainingList" class="table table-bordered table-striped" style="width: 100%; margin-bottom: 0;">
                                        <thead>
                                            <tr>
                                                <th style="text-align: center; width: 40%;">Training Name</th>
                                                <th style="text-align: center; width: 40%;">Training Type</th>
                                                <th style="text-align: center; width: 20%;">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody></tbody>
                                    </table>
                                </div>
                                
                                <!-- Hidden fields to store training data -->
                                <input type="hidden" id="hdnTrainingItemId" />
                                <input type="hidden" id="hdnTrainingRequirementName" />
                            </div>
                        </div>
                    </div>

                    <div id="modalValidationAlert" class="alert alert-danger" style="display: none;"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn" style="color:white" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSaveGoalModal">Save Goal</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" role="dialog" id="AssesmentModal" data-url="@Url.Action("GetAssesmentModal")">
    <div class="modal-dialog modal-lg" role="document" style="width: 700px; max-width: 90%;">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title">Self Assessment</h4>
            </div>
            <div class="modal-body" style="padding: 0;">
                <div id="SelfAssesmentContent">
                </div>
            </div>
        </div><!-- /.modal-content -->
    </div><!-- /.modal-dialog -->
</div><!-- /.modal -->

<!-- Copy KRA Modal -->
<div class="modal fade" id="copyKRAModal" tabindex="-1" role="dialog" aria-labelledby="copyKRAModalLabel">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title" id="copyKRAModalLabel">Copy Previous Year Goals & Objectives</h4>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label for="ddlAppraisalCycleCopyKRAModal">Select Appraisal Cycle:</label>
                    <select id="ddlAppraisalCycleCopyKRAModal" class="form-control">
                        <option value="0">-- Select Appraisal Cycle to Copy G&Os --</option>
                    </select>
                </div>
                
                <div id="copyKRALoader" style="display: none; text-align: center; padding: 20px;">
                    <i class="fa fa-spinner fa-spin" style="font-size: 24px; color: #337ab7;"></i>
                    <p>Loading Goals & Objectives...</p>
                </div>
                
                <div id="copyKRAContent" style="display: none;">
                    <div class="form-group">
                        <label>Goals & Objectives to Copy:</label>
                        <div style="max-height: 400px; overflow-y: auto; border: 1px solid #ddd; padding: 10px;">
                            <table class="table table-bordered table-striped" id="tblCopyKRAList">
                                <thead>
                                    <tr>
                                        <th>Goal Type</th>
                                        <th>Goal Description</th>
                                        <th>Weightage</th>
                                        <th>Measure</th>
                                    </tr>
                                </thead>
                                <tbody id="tblCopyKRAListBody">
                                    <!-- KRAs will be loaded here -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                
                <div id="copyKRANoData" style="display: none; text-align: center; padding: 20px; color: #999;">
                    <p>No Goals & Objectives found for the selected cycle.</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn" data-dismiss="modal" style="color:white">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnCopyKRASubmit" style="display: none;">Copy Selected G&Os</button>
            </div>
        </div>
    </div>
</div>

<!-- Reference Goal Repository Modal -->
<div class="modal fade" id="referenceGoalRepositoryModal" tabindex="-1" role="dialog" aria-labelledby="referenceGoalRepositoryModalLabel">
    <div class="modal-dialog modal-lg" role="document" style="width: 95%; max-width: 1400px; margin: 30px auto;">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close" style="color: #fff; opacity: 1;">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title" id="referenceGoalRepositoryModalLabel">Reference Goal Repository</h4>
            </div>
            <div class="modal-body" style="padding: 0;">
                <!-- Tab Navigation -->
                <ul class="nav nav-tabs" id="referenceGoalTabs" role="tablist" style="margin: 0; padding-left: 15px; padding-right: 15px; padding-top: 15px; background: #f5f5f5;">
                    <li role="presentation" class="active">
                        <a href="#refGoalMasterTab" id="refGoalMasterTabLink" aria-controls="refGoalMasterTab" role="tab" data-toggle="tab" style="font-weight: 500;">
                            <i class="glyphicon glyphicon-list-alt" style="margin-right: 5px;"></i>Reference Goal Master
                        </a>
                    </li>
                    <li role="presentation">
                        <a href="#previousYearGoalTab" id="previousYearGoalTabLink" aria-controls="previousYearGoalTab" role="tab" data-toggle="tab" style="font-weight: 500;">
                            <i class="glyphicon glyphicon-copy" style="margin-right: 5px;"></i>View Previous Year's Goal
                        </a>
                    </li>
                </ul>

                <!-- Tab Content -->
                <div class="tab-content" style="padding: 20px;">
                    <!-- Reference Goal Master Tab -->
                    <div role="tabpanel" class="tab-pane active" id="refGoalMasterTab">
                        <!-- Grade Filter -->
                        <div class="form-group" style="margin-bottom: 15px; display: flex; align-items: center; justify-content: flex-end;">
                            <label for="ddlReferenceGoalGrade" style="font-weight: bold; margin-right: 10px; margin-bottom: 0;">Grade:</label>
                            <select id="ddlReferenceGoalGrade" class="form-control" style="width: 200px; display: inline-block; max-height: 250px; overflow-y: auto;" size="1">
                                <option value="">Loading...</option>
                            </select>
                        </div>
                        
                        <div id="referenceGoalMasterLoader" style="display: none; text-align: center; padding: 40px;">
                            <i class="fa fa-spinner fa-spin" style="font-size: 36px; color: #337ab7;"></i>
                            <p style="margin-top: 15px; font-size: 16px;">Loading Reference Goals...</p>
                        </div>
                        
